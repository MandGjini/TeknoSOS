@page
@model TeknoSOS.WebApp.Areas.Identity.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Rikuperoni Fjalëkalimin";
    Layout = null;
}

<!DOCTYPE html>
<html lang="sq">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TeknoSOS</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" href="~/favicon.ico" />
    
    <style>
        :root {
            --primary-orange: #F28C28;
            --primary-red: #D7263D;
            --primary-green: #2ECC71;
            --primary-dark: #0B2545;
            --primary-light: #F5F5F5;
        }
        
        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            background: linear-gradient(135deg, var(--primary-dark) 0%, #13365a 50%, var(--primary-dark) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }
        
        .forgot-card {
            max-width: 450px;
            width: 100%;
            background: white;
            border-radius: 24px;
            padding: 2.5rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4);
        }
        
        .forgot-header {
            text-align: center;
            margin-bottom: 2rem;
        }
        
        .forgot-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, var(--primary-orange), var(--primary-red));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
        }
        
        .forgot-icon i {
            font-size: 2rem;
            color: white;
        }
        
        .forgot-header h2 {
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--primary-dark);
            margin-bottom: 0.5rem;
        }
        
        .forgot-header p {
            color: #64748b;
            font-size: 0.95rem;
        }
        
        .form-floating {
            margin-bottom: 1.25rem;
        }
        
        .form-floating .form-control {
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            padding: 1.5rem 1rem 0.75rem 1rem;
            height: 60px;
            font-size: 1rem;
            transition: all 0.3s ease;
        }
        
        .form-floating .form-control:focus {
            border-color: var(--primary-orange);
            box-shadow: 0 0 0 4px rgba(242, 140, 40, 0.1);
        }
        
        .form-floating label {
            padding: 1rem;
            color: #64748b;
        }
        
        .btn-submit {
            width: 100%;
            padding: 1rem;
            font-size: 1.1rem;
            font-weight: 600;
            border: none;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--primary-orange) 0%, var(--primary-red) 100%);
            color: white;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(242, 140, 40, 0.4);
        }
        
        .back-link {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            margin-top: 1.5rem;
            color: #64748b;
            text-decoration: none;
            font-size: 0.95rem;
            transition: color 0.2s;
        }
        
        .back-link:hover {
            color: var(--primary-orange);
        }
        
        .validation-summary-errors ul {
            list-style: none;
            padding: 1rem;
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 12px;
            margin-bottom: 1.5rem;
        }
        
        .validation-summary-errors ul li {
            color: #dc2626;
            font-size: 0.9rem;
        }
        
        .field-validation-error {
            color: #dc2626;
            font-size: 0.8rem;
            margin-top: 0.25rem;
        }
        
        .success-message {
            padding: 1rem;
            background: #f0fdf4;
            border: 1px solid #bbf7d0;
            border-radius: 12px;
            margin-bottom: 1.5rem;
            color: #166534;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="forgot-card">
        <div class="forgot-header">
            <div class="forgot-icon">
                <i class="bi bi-key"></i>
            </div>
            <h2>Keni harruar fjalëkalimin?</h2>
            <p>Vendosni email-in tuaj dhe do t'ju dërgojmë një link për ta rivendosur</p>
        </div>
        
        @if (Model.EmailSent)
        {
            <div class="success-message">
                <i class="bi bi-check-circle me-2"></i>
                Nëse ekziston një llogari me këtë email, do të merrni një link për rivendosjen e fjalëkalimit.
            </div>
        }
        
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
            
            <div class="form-floating">
                <input asp-for="Input.Email" 
                       class="form-control" 
                       id="email" 
                       placeholder="Email" 
                       autocomplete="email" />
                <label asp-for="Input.Email">
                    <i class="bi bi-envelope me-2"></i>Email
                </label>
            </div>
            <span asp-validation-for="Input.Email" class="field-validation-error"></span>
            
            <button type="submit" class="btn-submit">
                <i class="bi bi-send me-2"></i>
                Dërgo Linkun e Rikuperimit
            </button>
        </form>
        
        <a asp-page="./Login" class="back-link">
            <i class="bi bi-arrow-left"></i>
            Kthehu te Login
        </a>
    </div>
</body>
</html>
