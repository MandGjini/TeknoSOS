@page
@model TeknoSOS.WebApp.Areas.Identity.Pages.Account.RegisterModel
@using TeknoSOS.WebApp.Domain.Enums
@{
    ViewData["Title"] = "Regjistrohu";
    Layout = null;
}

<!DOCTYPE html>
<html lang="sq">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TeknoSOS</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" href="~/favicon.ico" />
    
    <style>
        body {
            background: linear-gradient(135deg, #0B2545 0%, #1a3a5c 50%, #0B2545 100%);
            min-height: 100vh;
            font-family: 'Inter', sans-serif;
        }
        
        .register-container {
            max-width: 700px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }
        
        .register-card {
            background: rgba(255, 255, 255, 0.98);
            border-radius: 24px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4);
            overflow: hidden;
        }
        
        .register-header {
            background: linear-gradient(135deg, #F28C28 0%, #D7263D 100%);
            padding: 2rem;
            text-align: center;
            color: white;
        }
        
        .register-header img {
            width: 64px;
            height: 64px;
            margin-bottom: 1rem;
        }
        
        .register-header h1 {
            font-weight: 800;
            margin-bottom: 0.5rem;
        }
        
        .register-body {
            padding: 2rem;
        }
        
        /* Step Progress */
        .step-progress {
            display: flex;
            justify-content: space-between;
            margin-bottom: 2rem;
            position: relative;
        }
        
        .step-progress::before {
            content: '';
            position: absolute;
            top: 20px;
            left: 50px;
            right: 50px;
            height: 3px;
            background: #e2e8f0;
            z-index: 0;
        }
        
        .step-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            z-index: 1;
            flex: 1;
        }
        
        .step-circle {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #e2e8f0;
            color: #64748b;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.9rem;
            transition: all 0.3s ease;
            border: 3px solid transparent;
        }
        
        .step-item.active .step-circle {
            background: #F28C28;
            color: white;
            border-color: #F28C28;
            box-shadow: 0 4px 12px rgba(242, 140, 40, 0.4);
        }
        
        .step-item.completed .step-circle {
            background: #2ECC71;
            color: white;
            border-color: #2ECC71;
        }
        
        .step-label {
            font-size: 0.75rem;
            font-weight: 600;
            color: #64748b;
            margin-top: 0.5rem;
            text-align: center;
        }
        
        .step-item.active .step-label {
            color: #F28C28;
        }
        
        .step-item.completed .step-label {
            color: #2ECC71;
        }
        
        /* Form Steps */
        .form-step {
            display: none;
        }
        
        .form-step.active {
            display: block;
            animation: fadeIn 0.3s ease;
        }
        
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        /* Role Cards */
        .role-card {
            border: 2px solid #e2e8f0;
            border-radius: 16px;
            padding: 1.5rem;
            cursor: pointer;
            transition: all 0.3s ease;
            text-align: center;
            height: 100%;
        }
        
        .role-card:hover {
            border-color: #F28C28;
            transform: translateY(-4px);
            box-shadow: 0 10px 25px rgba(242, 140, 40, 0.15);
        }
        
        .role-card.selected {
            border-color: #F28C28;
            background: linear-gradient(135deg, rgba(242, 140, 40, 0.08), rgba(215, 38, 61, 0.05));
            box-shadow: 0 10px 25px rgba(242, 140, 40, 0.2);
        }
        
        .role-card input[type="radio"] {
            display: none;
        }
        
        .role-icon {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            margin: 0 auto 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
        }
        
        .role-citizen .role-icon {
            background: linear-gradient(135deg, #2ECC71, #27ae60);
            color: white;
        }
        
        .role-professional .role-icon {
            background: linear-gradient(135deg, #F28C28, #D7263D);
            color: white;
        }
        
        .role-card h4 {
            font-weight: 700;
            color: #0B2545;
            margin-bottom: 0.5rem;
        }
        
        .role-card p {
            font-size: 0.875rem;
            color: #64748b;
            margin-bottom: 0;
        }
        
        .role-features {
            margin-top: 1rem;
            text-align: left;
        }
        
        .role-features li {
            font-size: 0.8rem;
            color: #475569;
            padding: 0.25rem 0;
        }
        
        .role-features i {
            color: #2ECC71;
            margin-right: 0.5rem;
        }
        
        /* Form Controls */
        .form-floating > .form-control,
        .form-floating > .form-select {
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            height: calc(3.5rem + 4px);
            padding: 1rem 1rem;
        }
        
        .form-floating > .form-control:focus,
        .form-floating > .form-select:focus {
            border-color: #F28C28;
            box-shadow: 0 0 0 3px rgba(242, 140, 40, 0.15);
        }
        
        .form-floating > label {
            padding: 1rem;
            color: #64748b;
        }
        
        /* Category Selection */
        .category-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 0.75rem;
        }
        
        .category-item {
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            padding: 0.75rem 1rem;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }
        
        .category-item:hover {
            border-color: #F28C28;
            background: rgba(242, 140, 40, 0.05);
        }
        
        .category-item.selected {
            border-color: #F28C28;
            background: rgba(242, 140, 40, 0.1);
        }
        
        .category-item input[type="checkbox"],
        .category-item input[type="radio"] {
            display: none;
        }
        
        .category-icon {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
        }
        
        .category-item span {
            font-size: 0.875rem;
            font-weight: 500;
            color: #0B2545;
        }
        
        .category-item .check-mark {
            margin-left: auto;
            color: #F28C28;
            opacity: 0;
            transition: opacity 0.2s;
        }
        
        .category-item.selected .check-mark {
            opacity: 1;
        }
        
        /* Buttons */
        .btn-register {
            background: linear-gradient(135deg, #F28C28, #D7263D);
            border: none;
            color: white;
            font-weight: 600;
            padding: 0.85rem 2rem;
            border-radius: 12px;
            font-size: 1rem;
            transition: all 0.3s ease;
        }
        
        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(242, 140, 40, 0.35);
            color: white;
        }
        
        .btn-outline-secondary {
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            font-weight: 600;
            padding: 0.85rem 2rem;
        }
        
        .btn-outline-secondary:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
        }
        
        /* Terms Checkbox */
        .terms-check {
            display: flex;
            align-items: flex-start;
            gap: 0.75rem;
            padding: 1rem;
            background: #f8fafc;
            border-radius: 12px;
            border: 2px solid #e2e8f0;
        }
        
        .terms-check input[type="checkbox"] {
            width: 20px;
            height: 20px;
            margin-top: 2px;
            accent-color: #F28C28;
        }
        
        .terms-check label {
            font-size: 0.875rem;
            color: #475569;
        }
        
        .terms-check a {
            color: #F28C28;
            font-weight: 600;
            text-decoration: none;
        }
        
        .terms-check a:hover {
            text-decoration: underline;
        }
        
        /* Validation */
        .field-validation-error {
            color: #D7263D;
            font-size: 0.8rem;
            margin-top: 0.25rem;
        }
        
        .input-validation-error {
            border-color: #D7263D !important;
        }
        
        /* Back to Home */
        .back-home {
            text-align: center;
            margin-top: 1.5rem;
        }
        
        .back-home a {
            color: white;
            text-decoration: none;
            font-weight: 500;
            opacity: 0.9;
            transition: opacity 0.2s;
        }
        
        .back-home a:hover {
            opacity: 1;
            color: white;
        }
        
        /* Responsive */
        @@media (max-width: 576px) {
            .register-container {
                padding: 1rem 0.5rem;
            }
            
            .register-body {
                padding: 1.5rem 1rem;
            }
            
            .step-progress::before {
                left: 30px;
                right: 30px;
            }
            
            .step-circle {
                width: 32px;
                height: 32px;
                font-size: 0.8rem;
            }
            
            .step-label {
                font-size: 0.65rem;
            }
            
            .category-grid {
                grid-template-columns: 1fr;
            }
                /* Make role cards same size and padding on mobile */
                .role-card {
                    padding: 1.2rem;
                    min-height: 340px;
                    font-size: 1rem;
                }
                .role-icon {
                    width: 64px;
                    height: 64px;
                    font-size: 1.5rem;
                }
                .role-card h4 {
                    font-size: 1.1rem;
                }
                .role-card p {
                    font-size: 0.9rem;
                }
        }
    </style>
</head>
<body>
    <div class="register-container">
        <div class="register-card">
            <div class="register-header">
                <img src="~/images/logo.png" alt="TeknoSOS Logo" />
                <h1>Regjistrohu në TeknoSOS</h1>
                <p class="mb-0 opacity-90">Krijo llogarinë tënde dhe fillo sot!</p>
            </div>
            
            <div class="register-body">
                <!-- Step Progress -->
                <div class="step-progress">
                    <div class="step-item active" data-step="1">
                        <div class="step-circle">1</div>
                        <span class="step-label">Lloji</span>
                    </div>
                    <div class="step-item" data-step="2">
                        <div class="step-circle">2</div>
                        <span class="step-label">Info</span>
                    </div>
                    <div class="step-item" data-step="3">
                        <div class="step-circle">3</div>
                        <span class="step-label">Vendndodhja</span>
                    </div>
                    <div class="step-item professional-step" data-step="4" style="display: none;">
                        <div class="step-circle">4</div>
                        <span class="step-label">Profesional</span>
                    </div>
                    <div class="step-item" data-step="5">
                        <div class="step-circle"><i class="bi bi-check-lg"></i></div>
                        <span class="step-label">Konfirmo</span>
                    </div>
                </div>
                
                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" novalidate>
                    <!-- Validation Summary -->
                    <div asp-validation-summary="All" class="alert alert-danger" role="alert" style="display:none;" id="validationErrors"></div>
                    
                    <!-- Step 1: Account Type -->
                    <div class="form-step active" data-step="1">
                        <h5 class="fw-bold mb-3 text-center" style="color: #0B2545;">Si dëshironi të regjistroheni?</h5>
                        <p class="text-muted text-center mb-4">Zgjidhni llojin e llogarisë që përputhet me nevojat tuaja</p>
                        
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="role-card role-citizen" onclick="selectRole(0)">
                                    <input type="radio" asp-for="Input.AccountType" value="0" />
                                    <div class="role-icon">
                                        <i class="bi bi-person"></i>
                                    </div>
                                    <h4>Qytetar / Klient</h4>
                                    <p>Kërkoj shërbime teknike për shtëpinë ose biznesin tim</p>
                                    <ul class="role-features list-unstyled">
                                        <li><i class="bi bi-check-circle-fill"></i> Raporto defekte</li>
                                        <li><i class="bi bi-check-circle-fill"></i> Gjej teknikë të certifikuar</li>
                                        <li><i class="bi bi-check-circle-fill"></i> Vlerëso shërbimet</li>
                                        <li><i class="bi bi-check-circle-fill"></i> Chat me teknikë</li>
                                    </ul>
                                </label>
                            </div>
                            <div class="col-md-6">
                                <label class="role-card role-professional" onclick="selectRole(1)">
                                    <input type="radio" asp-for="Input.AccountType" value="1" />
                                    <div class="role-icon">
                                        <i class="bi bi-tools"></i>
                                    </div>
                                    <h4>Profesionist / Teknik</h4>
                                    <p>Ofroj shërbime teknike si hidraulik, elektrik, HVAC, etj.</p>
                                    <ul class="role-features list-unstyled">
                                        <li><i class="bi bi-check-circle-fill"></i> Prano kërkesa nga klientë</li>
                                        <li><i class="bi bi-check-circle-fill"></i> Menaxho profile profesional</li>
                                        <li><i class="bi bi-check-circle-fill"></i> Merr vlerësime dhe komente</li>
                                        <li><i class="bi bi-check-circle-fill"></i> Chat me klientë</li>
                                    </ul>
                                    <div class="alert alert-info mt-3 mb-0 p-2" style="font-size:0.93rem;">
                                        <i class="bi bi-shield-lock me-1"></i>
                                        Llogaritë e teknikëve kërkojnë konfirmim nga administratori para se të aktivizohen.
                                    </div>
                                </label>
                            </div>
                        </div>
                        <span asp-validation-for="Input.AccountType" class="field-validation-error"></span>
                        
                        <div class="d-flex justify-content-end mt-4">
                            <button type="button" class="btn btn-register" onclick="nextStep()">
                                Vazhdo <i class="bi bi-arrow-right ms-2"></i>
                            </button>
                        </div>
                    </div>
                    
                    <!-- Step 2: Basic Info -->
                    <div class="form-step" data-step="2">
                        <h5 class="fw-bold mb-3" style="color: #0B2545;"><i class="bi bi-person-badge me-2" style="color: #F28C28;"></i>Informacionet Bazë</h5>
                        
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Input.FirstName" class="form-control" placeholder="Emri" />
                                    <label asp-for="Input.FirstName"><i class="bi bi-person me-1"></i> Emri *</label>
                                </div>
                                <span asp-validation-for="Input.FirstName" class="field-validation-error"></span>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Input.LastName" class="form-control" placeholder="Mbiemri" />
                                    <label asp-for="Input.LastName"><i class="bi bi-person me-1"></i> Mbiemri *</label>
                                </div>
                                <span asp-validation-for="Input.LastName" class="field-validation-error"></span>
                            </div>
                            <div class="col-12">
                                <div class="form-floating">
                                    <input asp-for="Input.Email" class="form-control" placeholder="Email" />
                                    <label asp-for="Input.Email"><i class="bi bi-envelope me-1"></i> Email *</label>
                                </div>
                                <span asp-validation-for="Input.Email" class="field-validation-error"></span>
                            </div>
                            <div class="col-12">
                                <div class="form-floating">
                                    <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Numri i Telefonit" />
                                    <label asp-for="Input.PhoneNumber"><i class="bi bi-telephone me-1"></i> Numri i Telefonit *</label>
                                </div>
                                <span asp-validation-for="Input.PhoneNumber" class="field-validation-error"></span>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Input.Password" class="form-control" placeholder="Fjalëkalimi" />
                                    <label asp-for="Input.Password"><i class="bi bi-lock me-1"></i> Fjalëkalimi *</label>
                                </div>
                                <span asp-validation-for="Input.Password" class="field-validation-error"></span>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Input.ConfirmPassword" class="form-control" placeholder="Konfirmo" />
                                    <label asp-for="Input.ConfirmPassword"><i class="bi bi-lock-fill me-1"></i> Konfirmo *</label>
                                </div>
                                <span asp-validation-for="Input.ConfirmPassword" class="field-validation-error"></span>
                            </div>
                        </div>
                        
                        <div class="d-flex justify-content-between mt-4">
                            <button type="button" class="btn btn-outline-secondary" onclick="prevStep()">
                                <i class="bi bi-arrow-left me-2"></i> Kthehu
                            </button>
                            <button type="button" class="btn btn-register" onclick="nextStep()">
                                Vazhdo <i class="bi bi-arrow-right ms-2"></i>
                            </button>
                        </div>
                    </div>
                    
                    <!-- Step 3: Location -->
                    <div class="form-step" data-step="3">
                        <h5 class="fw-bold mb-3" style="color: #0B2545;"><i class="bi bi-geo-alt me-2" style="color: #2ECC71;"></i>Vendndodhja</h5>
                        
                        <div class="row g-3">
                            <div class="col-12">
                                <div class="form-floating">
                                    <select asp-for="Input.City" class="form-select">
                                        <option value="">Zgjidhni qytetin...</option>
                                        <option value="Tiranë">Tiranë</option>
                                        <option value="Durrës">Durrës</option>
                                        <option value="Vlorë">Vlorë</option>
                                        <option value="Shkodër">Shkodër</option>
                                        <option value="Elbasan">Elbasan</option>
                                        <option value="Fier">Fier</option>
                                        <option value="Korçë">Korçë</option>
                                        <option value="Berat">Berat</option>
                                        <option value="Lushnjë">Lushnjë</option>
                                        <option value="Pogradec">Pogradec</option>
                                        <option value="Kavajë">Kavajë</option>
                                        <option value="Gjirokastër">Gjirokastër</option>
                                        <option value="Sarandë">Sarandë</option>
                                        <option value="Lezhë">Lezhë</option>
                                        <option value="Kukës">Kukës</option>
                                        <option value="Peshkopi">Peshkopi</option>
                                        <option value="Tjetër">Tjetër</option>
                                    </select>
                                    <label asp-for="Input.City"><i class="bi bi-building me-1"></i> Qyteti</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating">
                                    <input asp-for="Input.Address" class="form-control" placeholder="Adresa" />
                                    <label asp-for="Input.Address"><i class="bi bi-signpost me-1"></i> Adresa (opsionale)</label>
                                </div>
                            </div>
                        </div>
                        
                        <div class="d-flex justify-content-between mt-4">
                            <button type="button" class="btn btn-outline-secondary" onclick="prevStep()">
                                <i class="bi bi-arrow-left me-2"></i> Kthehu
                            </button>
                            <button type="button" class="btn btn-register" onclick="nextStep()">
                                Vazhdo <i class="bi bi-arrow-right ms-2"></i>
                            </button>
                        </div>
                    </div>
                    
                    <!-- Step 4: Professional Details (only for professionals) -->
                    <div class="form-step professional-only" data-step="4">
                        <h5 class="fw-bold mb-3" style="color: #0B2545;"><i class="bi bi-briefcase me-2" style="color: #D7263D;"></i>Detajet Profesionale</h5>
                        
                        <div class="mb-4">
                            <label class="form-label fw-semibold mb-2">Kategoria Kryesore e Shërbimit *</label>
                            <div class="category-grid">
                                <label class="category-item" onclick="selectCategory(this, 'primary')">
                                    <input type="radio" name="Input.PrimaryCategory" value="0" />
                                    <div class="category-icon" style="background: #3498db; color: white;"><i class="bi bi-droplet"></i></div>
                                    <span>Hidraulik</span>
                                    <i class="bi bi-check-circle-fill check-mark"></i>
                                </label>
                                <label class="category-item" onclick="selectCategory(this, 'primary')">
                                    <input type="radio" name="Input.PrimaryCategory" value="1" />
                                    <div class="category-icon" style="background: #f1c40f; color: #333;"><i class="bi bi-lightning"></i></div>
                                    <span>Elektrik</span>
                                    <i class="bi bi-check-circle-fill check-mark"></i>
                                </label>
                                <label class="category-item" onclick="selectCategory(this, 'primary')">
                                    <input type="radio" name="Input.PrimaryCategory" value="2" />
                                    <div class="category-icon" style="background: #1abc9c; color: white;"><i class="bi bi-thermometer-half"></i></div>
                                    <span>HVAC/Klima</span>
                                    <i class="bi bi-check-circle-fill check-mark"></i>
                                </label>
                                <label class="category-item" onclick="selectCategory(this, 'primary')">
                                    <input type="radio" name="Input.PrimaryCategory" value="3" />
                                    <div class="category-icon" style="background: #95a5a6; color: white;"><i class="bi bi-wrench"></i></div>
                                    <span>Gjenerale</span>
                                    <i class="bi bi-check-circle-fill check-mark"></i>
                                </label>
                                <label class="category-item" onclick="selectCategory(this, 'primary')">
                                    <input type="radio" name="Input.PrimaryCategory" value="4" />
                                    <div class="category-icon" style="background: #8B4513; color: white;"><i class="bi bi-hammer"></i></div>
                                    <span>Marangoz</span>
                                    <i class="bi bi-check-circle-fill check-mark"></i>
                                </label>
                                <label class="category-item" onclick="selectCategory(this, 'primary')">
                                    <input type="radio" name="Input.PrimaryCategory" value="5" />
                                    <div class="category-icon" style="background: #e74c3c; color: white;"><i class="bi bi-tv"></i></div>
                                    <span>Elektroshtëpiake</span>
                                    <i class="bi bi-check-circle-fill check-mark"></i>
                                </label>
                                <label class="category-item" onclick="selectCategory(this, 'primary')">
                                    <input type="radio" name="Input.PrimaryCategory" value="6" />
                                    <div class="category-icon" style="background: #34495e; color: white;"><i class="bi bi-gear"></i></div>
                                    <span>Mekanik</span>
                                    <i class="bi bi-check-circle-fill check-mark"></i>
                                </label>
                                <label class="category-item" onclick="selectCategory(this, 'primary')">
                                    <input type="radio" name="Input.PrimaryCategory" value="7" />
                                    <div class="category-icon" style="background: #9b59b6; color: white;"><i class="bi bi-pc-display"></i></div>
                                    <span>IT/Teknologji</span>
                                    <i class="bi bi-check-circle-fill check-mark"></i>
                                </label>
                            </div>
                        </div>
                        
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Input.YearsOfExperience" type="number" class="form-control" min="0" max="50" placeholder="0" />
                                    <label asp-for="Input.YearsOfExperience"><i class="bi bi-calendar me-1"></i> Vitet e Eksperiencës</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Input.ServiceRadiusKm" type="number" class="form-control" min="1" max="100" placeholder="10" />
                                    <label asp-for="Input.ServiceRadiusKm"><i class="bi bi-radar me-1"></i> Rrezja e Shërbimit (km)</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Input.CompanyName" class="form-control" placeholder="Kompania" />
                                    <label asp-for="Input.CompanyName"><i class="bi bi-building me-1"></i> Emri i Kompanisë</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Input.LicenseNumber" class="form-control" placeholder="Licenca" />
                                    <label asp-for="Input.LicenseNumber"><i class="bi bi-card-text me-1"></i> Nr. Licencës</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating">
                                    <textarea asp-for="Input.Bio" class="form-control" style="height: 100px" placeholder="Bio"></textarea>
                                    <label asp-for="Input.Bio"><i class="bi bi-text-paragraph me-1"></i> Përshkrimi juaj profesional</label>
                                </div>
                            </div>
                        </div>
                        
                        <div class="d-flex justify-content-between mt-4">
                            <button type="button" class="btn btn-outline-secondary" onclick="prevStep()">
                                <i class="bi bi-arrow-left me-2"></i> Kthehu
                            </button>
                            <button type="button" class="btn btn-register" onclick="nextStep()">
                                Vazhdo <i class="bi bi-arrow-right ms-2"></i>
                            </button>
                        </div>
                    </div>
                    
                    <!-- Step 5: Confirmation -->
                    <div class="form-step" data-step="5">
                        <h5 class="fw-bold mb-3 text-center" style="color: #0B2545;"><i class="bi bi-shield-check me-2" style="color: #2ECC71;"></i>Konfirmo Regjistrimin</h5>
                        
                        <div class="alert alert-info mb-4" style="background: rgba(242,140,40,0.1); border-color: #F28C28; color: #0B2545;">
                            <i class="bi bi-info-circle me-2"></i>
                            Ju lutem rishikoni informacionet dhe pranoni kushtet për të përfunduar regjistrimin.
                        </div>
                        
                        <!-- Summary -->
                        <div class="card mb-4" style="border: 2px solid #e2e8f0; border-radius: 16px;">
                            <div class="card-body">
                                <h6 class="fw-bold mb-3"><i class="bi bi-person-badge me-2" style="color: #F28C28;"></i>Përmbledhja</h6>
                                <div class="row small">
                                    <div class="col-6 mb-2">
                                        <span class="text-muted">Lloji:</span><br>
                                        <strong id="summaryRole">-</strong>
                                    </div>
                                    <div class="col-6 mb-2">
                                        <span class="text-muted">Emri:</span><br>
                                        <strong id="summaryName">-</strong>
                                    </div>
                                    <div class="col-6 mb-2">
                                        <span class="text-muted">Email:</span><br>
                                        <strong id="summaryEmail">-</strong>
                                    </div>
                                    <div class="col-6 mb-2">
                                        <span class="text-muted">Telefon:</span><br>
                                        <strong id="summaryPhone">-</strong>
                                    </div>
                                    <div class="col-6 mb-2">
                                        <span class="text-muted">Qyteti:</span><br>
                                        <strong id="summaryCity">-</strong>
                                    </div>
                                    <div class="col-6 mb-2 professional-summary" style="display: none;">
                                        <span class="text-muted">Kategoria:</span><br>
                                        <strong id="summaryCategory">-</strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Terms -->
                        <div class="terms-check mb-4">
                            <input asp-for="Input.AcceptTerms" type="checkbox" id="acceptTerms" />
                            <label for="acceptTerms">
                                Pranoj <a href="/Terms" target="_blank">Kushtet e Shërbimit</a> dhe 
                                <a href="/Privacy" target="_blank">Politikën e Privatësisë</a> të TeknoSOS.
                                Kuptoj që të dhënat e mia do të përdoren sipas këtyre kushteve.
                            </label>
                        </div>
                        <span asp-validation-for="Input.AcceptTerms" class="field-validation-error d-block mb-3"></span>
                        
                        <div class="d-flex justify-content-between">
                            <button type="button" class="btn btn-outline-secondary" onclick="prevStep()">
                                <i class="bi bi-arrow-left me-2"></i> Kthehu
                            </button>
                            <button type="button" class="btn btn-register btn-lg" onclick="submitRegistration()">
                                <i class="bi bi-check-circle me-2"></i> Regjistrohu Tani
                            </button>
                        </div>
                    </div>
                </form>
                
                <!-- Login Link -->
                <div class="text-center mt-4 pt-3" style="border-top: 1px solid #e2e8f0;">
                    <span class="text-muted">Keni tashmë llogari?</span>
                    <a asp-area="Identity" asp-page="/Account/Login" class="fw-bold ms-1" style="color: #F28C28; text-decoration: none;">Hyni këtu</a>
                </div>
            </div>
        </div>
        
        <div class="back-home">
            <a href="/"><i class="bi bi-arrow-left me-1"></i> Kthehu në faqen kryesore</a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let currentStep = 1;
        let isProfessional = false;
        const totalSteps = 5;
        
        function selectRole(role) {
            isProfessional = role === 1;
            document.querySelectorAll('.role-card').forEach(card => card.classList.remove('selected'));
            event.currentTarget.classList.add('selected');
            
            // Show/hide professional step
            const profStep = document.querySelector('.professional-step');
            if (isProfessional) {
                profStep.style.display = 'flex';
            } else {
                profStep.style.display = 'none';
            }
            
            // Update step numbers
            updateStepNumbers();
        }
        
        function updateStepNumbers() {
            const steps = document.querySelectorAll('.step-item:not(.professional-step)');
            const profStep = document.querySelector('.professional-step');
            
            if (isProfessional) {
                // 1, 2, 3, 4, 5
                steps[3].querySelector('.step-circle').innerHTML = '5';
            } else {
                // 1, 2, 3, 4 (no professional step)
                steps[3].querySelector('.step-circle').innerHTML = '<i class="bi bi-check-lg"></i>';
            }
        }
        
        function nextStep() {
            if (currentStep === 3 && !isProfessional) {
                // Skip professional step
                currentStep = 5;
            } else if (currentStep < 5) {
                currentStep++;
            }
            
            if (currentStep === 5) {
                updateSummary();
            }
            
            showStep(currentStep);
        }
        
        function prevStep() {
            if (currentStep === 5 && !isProfessional) {
                // Skip professional step
                currentStep = 3;
            } else if (currentStep > 1) {
                currentStep--;
            }
            
            showStep(currentStep);
        }
        
        function showStep(step) {
            // Hide all steps
            document.querySelectorAll('.form-step').forEach(s => s.classList.remove('active'));
            
            // Show current step
            const activeStep = document.querySelector(`.form-step[data-step="${step}"]`);
            if (activeStep) {
                activeStep.classList.add('active');
            }
            
            // Update progress
            document.querySelectorAll('.step-item').forEach(item => {
                const itemStep = parseInt(item.dataset.step);
                item.classList.remove('active', 'completed');
                
                if (itemStep === step) {
                    item.classList.add('active');
                } else if (itemStep < step) {
                    item.classList.add('completed');
                }
            });
        }
        
        function selectCategory(element, type) {
            if (type === 'primary') {
                document.querySelectorAll('.category-item').forEach(item => {
                    if (item.querySelector('input[type="radio"]')) {
                        item.classList.remove('selected');
                    }
                });
            }
            element.classList.toggle('selected');
        }
        
        function updateSummary() {
            const role = document.querySelector('input[name="Input.AccountType"]:checked');
            const firstName = document.querySelector('input[name="Input.FirstName"]').value;
            const lastName = document.querySelector('input[name="Input.LastName"]').value;
            const email = document.querySelector('input[name="Input.Email"]').value;
            const phone = document.querySelector('input[name="Input.PhoneNumber"]').value;
            const city = document.querySelector('select[name="Input.City"]').value;
            
            document.getElementById('summaryRole').textContent = isProfessional ? 'Profesionist' : 'Qytetar/Klient';
            document.getElementById('summaryName').textContent = `${firstName} ${lastName}`;
            document.getElementById('summaryEmail').textContent = email;
            document.getElementById('summaryPhone').textContent = phone;
            document.getElementById('summaryCity').textContent = city || '-';
            
            // Professional summary
            if (isProfessional) {
                document.querySelectorAll('.professional-summary').forEach(el => el.style.display = 'block');
                const category = document.querySelector('input[name="Input.PrimaryCategory"]:checked');
                if (category) {
                    const categoryNames = ['Hidraulik', 'Elektrik', 'HVAC/Klima', 'Gjenerale', 'Marangoz', 'Elektroshtëpiake', 'Mekanik', 'IT/Teknologji'];
                    document.getElementById('summaryCategory').textContent = categoryNames[parseInt(category.value)];
                }
            } else {
                document.querySelectorAll('.professional-summary').forEach(el => el.style.display = 'none');
            }
        }
        
        function submitRegistration() {
            // Basic validation
            const firstName = document.querySelector('input[name="Input.FirstName"]').value.trim();
            const lastName = document.querySelector('input[name="Input.LastName"]').value.trim();
            const email = document.querySelector('input[name="Input.Email"]').value.trim();
            const phone = document.querySelector('input[name="Input.PhoneNumber"]').value.trim();
            const password = document.querySelector('input[name="Input.Password"]').value;
            const confirmPassword = document.querySelector('input[name="Input.ConfirmPassword"]').value;
            const acceptTerms = document.getElementById('acceptTerms').checked;
            
            let errors = [];
            
            if (!firstName) errors.push('Emri është i detyrueshëm');
            if (!lastName) errors.push('Mbiemri është i detyrueshëm');
            if (!email) errors.push('Email-i është i detyrueshëm');
            if (!email.includes('@@')) errors.push('Email-i nuk është i vlefshëm');
            if (!phone) errors.push('Numri i telefonit është i detyrueshëm');
            if (!password) errors.push('Fjalëkalimi është i detyrueshëm');
            if (password.length < 6) errors.push('Fjalëkalimi duhet të ketë të paktën 6 karaktere');
            if (password !== confirmPassword) errors.push('Fjalëkalimet nuk përputhen');
            if (!acceptTerms) errors.push('Duhet të pranoni Kushtet e Shërbimit');
            
            if (errors.length > 0) {
                const errorDiv = document.getElementById('validationErrors');
                errorDiv.innerHTML = '<ul class="mb-0">' + errors.map(e => '<li>' + e + '</li>').join('') + '</ul>';
                errorDiv.style.display = 'block';
                // Scroll to top to show errors
                document.querySelector('.register-body').scrollIntoView({ behavior: 'smooth' });
                return;
            }
            
            // Hide any previous errors
            document.getElementById('validationErrors').style.display = 'none';
            
            // Show loading state
            const btn = event.target;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Duke u regjistruar...';
            
            // Submit the form
            document.getElementById('registerForm').submit();
        }
        
        // Initialize - select Citizen by default
        document.addEventListener('DOMContentLoaded', function() {
            const citizenCard = document.querySelector('.role-citizen');
            if (citizenCard) {
                citizenCard.classList.add('selected');
                citizenCard.querySelector('input[type="radio"]').checked = true;
            }
            updateStepNumbers();
        });
    </script>
    
    <!-- jQuery and validation scripts -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
