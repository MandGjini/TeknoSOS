@page
@model TeknoSOS.WebApp.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Hyr";
    Layout = null;
}

<!DOCTYPE html>
<html lang="sq" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TeknoSOS</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" href="~/favicon.ico" />
    
    <!-- Theme detection -->
    <script>
        (function(){
            var saved = localStorage.getItem('ts-theme');
            var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            var theme = saved || (prefersDark ? 'dark' : 'light');
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>
    
    <style>
        :root {
            --login-primary: #F28C28;
            --login-red: #D7263D;
            --login-green: #2ECC71;
            --login-dark: #0B2545;
            --login-light: #F5F5F5;
            --login-form-bg: #F5F5F5;
            --login-card-bg: white;
            --login-text: #0B2545;
            --login-text-muted: #64748b;
            --login-border: #e2e8f0;
        }
        
        /* Dark mode colors */
        @@media (prefers-color-scheme: dark) {
            :root:not([data-theme="light"]) {
                --login-form-bg: #0f1f35;
                --login-card-bg: #162844;
                --login-text: #f8fafc;
                --login-text-muted: #94a3b8;
                --login-border: #2a4a70;
                --login-light: #0f1f35;
            }
        }
        
        [data-theme="dark"] {
            --login-form-bg: #0f1f35;
            --login-card-bg: #162844;
            --login-text: #f8fafc;
            --login-text-muted: #94a3b8;
            --login-border: #2a4a70;
            --login-light: #0f1f35;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            overflow-x: hidden;
        }
        
        .login-wrapper {
            display: flex;
            min-height: 100vh;
        }
        
        /* Left Side - Branding */
        .login-branding {
            flex: 1;
            background: linear-gradient(135deg, var(--primary-dark) 0%, #13365a 50%, var(--primary-dark) 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 3rem;
            position: relative;
            overflow: hidden;
        }
        
        .login-branding::before {
            content: '';
            position: absolute;
            width: 600px;
            height: 600px;
            background: linear-gradient(135deg, var(--primary-orange), var(--primary-red));
            border-radius: 50%;
            top: -300px;
            right: -200px;
            opacity: 0.1;
            animation: float 8s ease-in-out infinite;
        }
        
        .login-branding::after {
            content: '';
            position: absolute;
            width: 400px;
            height: 400px;
            background: linear-gradient(135deg, var(--primary-green), var(--primary-orange));
            border-radius: 50%;
            bottom: -200px;
            left: -100px;
            opacity: 0.1;
            animation: float 6s ease-in-out infinite reverse;
        }
        
        @@keyframes float {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(5deg); }
        }
        
        .branding-content {
            text-align: center;
            color: white;
            position: relative;
            z-index: 2;
        }
        
        .branding-logo {
            width: 120px;
            height: 120px;
            margin-bottom: 2rem;
            filter: drop-shadow(0 10px 25px rgba(0,0,0,0.3));
            animation: logoFloat 4s ease-in-out infinite;
        }
        
        @@keyframes logoFloat {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        
        .branding-title {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 1rem;
            background: linear-gradient(135deg, #fff 0%, rgba(255,255,255,0.8) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .branding-subtitle {
            font-size: 1.25rem;
            opacity: 0.9;
            margin-bottom: 3rem;
            max-width: 400px;
        }
        
        .features-list {
            list-style: none;
            text-align: left;
            margin-top: 2rem;
        }
        
        .features-list li {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1rem;
            font-size: 1rem;
            opacity: 0.9;
        }
        
        .features-list li i {
            color: var(--primary-green);
            font-size: 1.25rem;
        }
        
        /* Right Side - Login Form */
        .login-form-section {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 3rem;
            background: var(--login-form-bg);
        }
        
        .login-card {
            max-width: 450px;
            width: 100%;
            margin: 0 auto;
        }
        
        .login-header {
            text-align: center;
            margin-bottom: 2rem;
        }
        
        .login-header h2 {
            font-size: 2rem;
            font-weight: 700;
            color: var(--login-text);
            margin-bottom: 0.5rem;
        }
        
        .login-header p {
            color: var(--login-text-muted);
            font-size: 1rem;
        }
        
        /* Form Styling */
        .form-floating {
            margin-bottom: 1.25rem;
        }
        
        .form-floating .form-control {
            border: 2px solid var(--login-border);
            border-radius: 12px;
            padding: 1.5rem 1rem 0.75rem 1rem;
            height: 60px;
            font-size: 1rem;
            background: var(--login-card-bg);
            color: var(--login-text);
            transition: all 0.3s ease;
        }
        
        .form-floating .form-control:focus {
            border-color: var(--login-primary);
            box-shadow: 0 0 0 4px rgba(242, 140, 40, 0.1);
            background: var(--login-card-bg);
            color: var(--login-text);
        }
        
        .form-floating label {
            padding: 1rem;
            color: var(--login-text-muted);
        }
        
        .input-icon-wrapper {
            position: relative;
        }
        
        .input-icon {
            position: absolute;
            right: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 1.25rem;
            z-index: 5;
        }
        
        .password-toggle {
            cursor: pointer;
            transition: color 0.2s;
        }
        
        .password-toggle:hover {
            color: var(--primary-orange);
        }
        
        /* Remember Me & Forgot Password */
        .form-options {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }
        
        .form-check {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .form-check-input {
            width: 1.25rem;
            height: 1.25rem;
            border: 2px solid var(--login-border);
            border-radius: 6px;
            cursor: pointer;
            background: var(--login-card-bg);
        }
        
        .form-check-input:checked {
            background-color: var(--login-primary);
            border-color: var(--login-primary);
        }
        
        .form-check-label {
            color: var(--login-text-muted);
            font-size: 0.9rem;
            cursor: pointer;
        }
        
        .forgot-password {
            color: var(--primary-orange);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            transition: color 0.2s;
        }
        
        .forgot-password:hover {
            color: var(--primary-red);
            text-decoration: underline;
        }
        
        /* Login Button */
        .btn-login {
            width: 100%;
            padding: 1rem;
            font-size: 1.1rem;
            font-weight: 600;
            border: none;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--login-primary) 0%, var(--login-red) 100%);
            color: white;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        
        .btn-login::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: left 0.5s;
        }
        
        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(242, 140, 40, 0.4);
        }
        
        .btn-login:hover::before {
            left: 100%;
        }
        
        .btn-login:active {
            transform: translateY(0);
        }
        
        .btn-login i {
            margin-right: 0.5rem;
        }
        
        /* Divider */
        .divider {
            display: flex;
            align-items: center;
            margin: 2rem 0;
            color: var(--login-text-muted);
            font-size: 0.9rem;
        }
        
        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--login-border);
        }
        
        .divider span {
            padding: 0 1rem;
        }
        
        /* Social Login */
        .social-login {
            display: flex;
            gap: 1rem;
        }
        
        .btn-social {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            padding: 0.875rem 1rem;
            border: 2px solid var(--login-border);
            border-radius: 12px;
            background: var(--login-card-bg);
            color: var(--login-text-muted);
            font-weight: 500;
            font-size: 0.9rem;
            text-decoration: none;
            transition: all 0.3s ease;
        }
        
        .btn-social:hover {
            border-color: var(--login-primary);
            background: var(--login-card-bg);
            color: var(--login-text);
            transform: translateY(-2px);
        }
        
        .btn-social i {
            font-size: 1.25rem;
        }
        
        .btn-google i { color: #DB4437; }
        .btn-facebook i { color: #4267B2; }
        
        /* Register Link */
        .register-link {
            text-align: center;
            margin-top: 2rem;
            color: var(--login-text-muted);
        }
        
        .register-link a {
            color: var(--login-primary);
            font-weight: 600;
            text-decoration: none;
            transition: color 0.2s;
        }
        
        .register-link a:hover {
            color: var(--login-red);
            text-decoration: underline;
        }
        
        /* Validation */
        .validation-summary-errors ul {
            list-style: none;
            padding: 1rem;
            background: rgba(220, 38, 38, 0.1);
            border: 1px solid rgba(220, 38, 38, 0.3);
            border-radius: 12px;
            margin-bottom: 1.5rem;
        }
        
        .validation-summary-errors ul li {
            color: #f87171;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .validation-summary-errors ul li::before {
            content: '\F33A';
            font-family: 'bootstrap-icons';
            color: #f87171;
        }
        
        .input-validation-error {
            border-color: #dc2626 !important;
        }
        
        .field-validation-error {
            color: #dc2626;
            font-size: 0.8rem;
            margin-top: 0.25rem;
            display: block;
        }
        
        /* Mobile Responsive */
        @@media (max-width: 767.98px) {
            .login-wrapper {
                flex-direction: column;
            }
            
            .login-branding {
                padding: 2rem;
                min-height: auto;
            }
            
            .branding-logo {
                width: 80px;
                height: 80px;
            }
            
            .branding-title {
                font-size: 2rem;
            }
            
            .branding-subtitle {
                font-size: 1rem;
                margin-bottom: 1rem;
            }
            
            .features-list {
                display: none;
            }
            
            .login-form-section {
                padding: 2rem 1.5rem;
            }
            
            /* Touch-friendly inputs */
            .form-control {
                font-size: 16px !important;
                padding: 0.85rem 1rem;
                min-height: 50px;
            }
            
            .btn {
                min-height: 50px;
                font-size: 1rem;
            }
        }
        
        @@media (max-width: 576px) {
            .social-login {
                flex-direction: column;
            }
            
            .form-options {
                flex-direction: column;
                gap: 1rem;
                align-items: flex-start;
            }
        }
        
        /* Loading State */
        .btn-login.loading {
            pointer-events: none;
            opacity: 0.8;
        }
        
        .btn-login.loading .btn-text {
            visibility: hidden;
        }
        
        .btn-login.loading::after {
            content: '';
            position: absolute;
            width: 24px;
            height: 24px;
            border: 3px solid rgba(255,255,255,0.3);
            border-top-color: white;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        
        @@keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Back to Home */
        .back-home {
            position: absolute;
            top: 1.5rem;
            left: 1.5rem;
            color: rgba(255,255,255,0.8);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.9rem;
            transition: color 0.2s;
            z-index: 10;
        }
        
        .back-home:hover {
            color: white;
        }
        
        @@media (max-width: 767.98px) {
            .back-home {
                color: var(--primary-dark);
                position: static;
                margin-bottom: 1rem;
            }
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <!-- Left Side - Branding -->
        <div class="login-branding d-none d-md-flex">
            <a href="/" class="back-home">
                <i class="bi bi-arrow-left"></i>
                Kthehu në Faqen Kryesore
            </a>
            
            <div class="branding-content">
                <img src="~/images/logo.png" alt="TeknoSOS" class="branding-logo" />
                <h1 class="branding-title">TeknoSOS</h1>
                <p class="branding-subtitle">Platforma juaj e besuar për zgjidhjen e problemeve teknike</p>
                
                <ul class="features-list">
                    <li>
                        <i class="bi bi-check-circle-fill"></i>
                        Raporto defekte në infrastrukturë
                    </li>
                    <li>
                        <i class="bi bi-check-circle-fill"></i>
                        Komuniko drejtpërdrejt me profesionistë
                    </li>
                    <li>
                        <i class="bi bi-check-circle-fill"></i>
                        Ndiq statusin e kërkesave në kohë reale
                    </li>
                    <li>
                        <i class="bi bi-check-circle-fill"></i>
                        Vlerëso dhe jep feedback
                    </li>
                    <li>
                        <i class="bi bi-check-circle-fill"></i>
                        24/7 mbështetje teknike
                    </li>
                </ul>
            </div>
        </div>
        
        <!-- Right Side - Login Form -->
        <div class="login-form-section">
            <div class="login-card">
                <!-- Mobile Back Link -->
                <a href="/" class="back-home d-md-none">
                    <i class="bi bi-arrow-left"></i>
                    Kthehu në Faqen Kryesore
                </a>
                
                <!-- Mobile Logo -->
                <div class="text-center d-md-none mb-4">
                    <img src="~/images/logo.png" alt="TeknoSOS" style="width: 60px; height: 60px;" />
                </div>
                
                <div class="login-header">
                    <h2>Mirë se vini përsëri!</h2>
                    <p>Hyni në llogarinë tuaj për të vazhduar</p>
                </div>
                
                <form id="login-form" method="post">
                    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
                    
                    <!-- Email -->
                    <div class="input-icon-wrapper">
                        <div class="form-floating">
                            <input asp-for="Input.Email" 
                                   class="form-control" 
                                   id="email" 
                                   placeholder="Email" 
                                   autocomplete="email" />
                            <label asp-for="Input.Email">
                                <i class="bi bi-envelope me-2"></i>Email
                            </label>
                        </div>
                        <span asp-validation-for="Input.Email" class="field-validation-error"></span>
                    </div>
                    
                    <!-- Password -->
                    <div class="input-icon-wrapper">
                        <div class="form-floating">
                            <input asp-for="Input.Password" 
                                   class="form-control" 
                                   id="password" 
                                   type="password"
                                   placeholder="Fjalëkalimi" 
                                   autocomplete="current-password" />
                            <label asp-for="Input.Password">
                                <i class="bi bi-lock me-2"></i>Fjalëkalimi
                            </label>
                            <i class="bi bi-eye input-icon password-toggle" 
                               onclick="togglePassword()" 
                               id="toggleIcon"></i>
                        </div>
                        <span asp-validation-for="Input.Password" class="field-validation-error"></span>
                    </div>
                    
                    <!-- Remember Me & Forgot Password -->
                    <div class="form-options">
                        <div class="form-check">
                            <input asp-for="Input.RememberMe" class="form-check-input" id="rememberMe" />
                            <label asp-for="Input.RememberMe" class="form-check-label">Më mbaj mend</label>
                        </div>
                        <a asp-page="./ForgotPassword" class="forgot-password">
                            Keni harruar fjalëkalimin?
                        </a>
                    </div>
                    
                    <!-- Login Button -->
                    <button type="submit" class="btn-login" id="loginBtn">
                        <span class="btn-text">
                            <i class="bi bi-box-arrow-in-right"></i>
                            Hyr në Llogari
                        </span>
                    </button>
                </form>
                
                <!-- Divider -->
                <div class="divider">
                    <span>ose vazhdoni me</span>
                </div>
                
                <!-- Social Login hidden by request -->
                <div class="social-login" style="display:none;">
                    <a class="btn-social btn-google" href="/signin-google">
                        <i class="bi bi-google"></i>
                        Hyr me Google
                    </a>
                    <span class="btn-social btn-facebook disabled" style="opacity: 0.6; cursor: default;" title="Së shpejti">
                        <i class="bi bi-facebook"></i>
                        Facebook <small class="text-muted">(së shpejti)</small>
                    </span>
                </div>
                
                <!-- Register Link -->
                <div class="register-link">
                    Nuk keni llogari? 
                    <a asp-page="./Register">Regjistrohuni falas</a>
                </div>
            </div>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Toggle Password Visibility
        function togglePassword() {
            const passwordInput = document.getElementById('password');
            const toggleIcon = document.getElementById('toggleIcon');
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleIcon.classList.remove('bi-eye');
                toggleIcon.classList.add('bi-eye-slash');
            } else {
                passwordInput.type = 'password';
                toggleIcon.classList.remove('bi-eye-slash');
                toggleIcon.classList.add('bi-eye');
            }
        }
        
        // Form Submit Loading State
        document.getElementById('login-form').addEventListener('submit', function(e) {
            const btn = document.getElementById('loginBtn');
            btn.classList.add('loading');
        });
        
        // Auto-focus email field
        document.addEventListener('DOMContentLoaded', function() {
            const emailInput = document.getElementById('email');
            if (emailInput && !emailInput.value) {
                emailInput.focus();
            }
        });
    </script>
</body>
</html>
