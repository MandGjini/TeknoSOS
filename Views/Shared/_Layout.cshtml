    <script>
        // Set active state for mobile nav based on current page
        (function() {
            const path = window.location.pathname.toLowerCase();
            const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');
            
            mobileNavLinks.forEach(link => {
                const href = link.getAttribute('href')?.toLowerCase() || '';
                link.classList.remove('active');
                
                if (path === '/' && href === '/') {
                    link.classList.add('active');
                } else if (href !== '/' && path.startsWith(href)) {
                    link.classList.add('active');
                }
            });
        })();
    </script>

    <!-- Banner Functions -->
    <script>
        function applyDeviceViewportClass() {
            const width = window.innerWidth || document.documentElement.clientWidth || 0;
            const root = document.documentElement;

            root.classList.remove('ts-device-mobile', 'ts-device-tablet', 'ts-device-desktop');

            if (width < 768) {
                root.classList.add('ts-device-mobile');
                root.setAttribute('data-device-size', 'mobile');
            } else if (width < 1200) {
                root.classList.add('ts-device-tablet');
                root.setAttribute('data-device-size', 'tablet');
            } else {
                root.classList.add('ts-device-desktop');
                root.setAttribute('data-device-size', 'desktop');
            }
        }

        applyDeviceViewportClass();
        window.addEventListener('resize', applyDeviceViewportClass);

        function closeBanner(bannerEl) {
            if (bannerEl) {
                bannerEl.classList.add('fade-out');
                setTimeout(() => bannerEl.remove(), 300);
            }
        }

        function trackBannerClick(bannerId) {
            fetch('/api/banners/' + bannerId + '/click', { method: 'POST' }).catch(() => {});
        }
    </script>

    <script>
        (function () {
            const toggleBtn = document.getElementById('globalAssistantToggle');
            const panel = document.getElementById('globalAssistantPanel');
            const closeBtn = document.getElementById('globalAssistantClose');
            const body = document.getElementById('globalAssistantBody');

            if (!toggleBtn || !panel || !body || window.matchMedia('(max-width: 991.98px)').matches) {
                return;
            }

            function addMessage(text, actions) {
                const box = document.createElement('div');
                box.className = 'global-assistant-msg';
                box.textContent = text;

                if (actions && actions.length) {
                    const actionWrap = document.createElement('div');
                    actionWrap.className = 'global-assistant-actions';

                    actions.forEach(action => {
                        const btn = document.createElement('button');
                        btn.type = 'button';
                        btn.textContent = action.label;
                        btn.addEventListener('click', action.onClick);
                        actionWrap.appendChild(btn);
                    });

                    box.appendChild(actionWrap);
                }

                body.appendChild(box);
                body.scrollTop = body.scrollHeight;
            }

            function startConversation() {
                if (body.dataset.started === '1') {
                    return;
                }

                body.dataset.started = '1';
                addMessage('Pershendetje! Une jam asistenti global ne desktop. Te ndihmoj te shkosh shpejt aty ku duhet.');

                addMessage('Cfare deshiron te besh?', [
                    { label: 'Raporto defekt', onClick: () => window.location.href = '/ReportDefect' },
                    { label: 'Shiko tekniket', onClick: () => window.location.href = '/Technicians' },
                    { label: 'Hap mesazhet', onClick: () => window.location.href = '/Messages' },
                    { label: 'Hap dashboard', onClick: () => window.location.href = '/Dashboard' }
                ]);

                const inReportPage = window.location.pathname.toLowerCase().includes('/reportdefect');
                if (inReportPage) {
                    addMessage('Je te Raporto Defekt. Mund te te ndihmoj te plotesosh formen me 1 klik:', [
                        {
                            label: 'Vendos prioritet Normal',
                            onClick: () => {
                                const radio = document.querySelector('input[name="Input.Priority"][value="Normal"]');
                                if (radio) {
                                    radio.checked = true;
                                    radio.dispatchEvent(new Event('change', { bubbles: true }));
                                }
                            }
                        },
                        {
                            label: 'Vendos prioritet Emergjent',
                            onClick: () => {
                                const radio = document.querySelector('input[name="Input.Priority"][value="Emergency"]');
                                if (radio) {
                                    radio.checked = true;
                                    radio.dispatchEvent(new Event('change', { bubbles: true }));
                                }
                            }
                        },
                        {
                            label: 'Shko te dergimi',
                            onClick: () => {
                                const btn = document.getElementById('submitBtn');
                                if (btn) {
                                    btn.scrollIntoView({ behavior: 'smooth', block: 'center' });
                                }
                            }
                        }
                    ]);
                }
            }

            toggleBtn.addEventListener('click', function () {
                const open = panel.style.display !== 'block';
                panel.style.display = open ? 'block' : 'none';
                if (open) {
                    startConversation();
                }
            });

            if (closeBtn) {
                closeBtn.addEventListener('click', function () {
                    panel.style.display = 'none';
                });
            }
        })();
    </script>
    
