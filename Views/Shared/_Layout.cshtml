@using TeknoSOS.WebApp.Domain.Entities
@using Microsoft.AspNetCore.Identity
@inject TeknoSOS.WebApp.Services.ISiteSettingsService SiteSettings
@inject UserManager<ApplicationUser> UserManager
@{
    var currentUser = User?.Identity?.IsAuthenticated ?? false
        ? await UserManager.GetUserAsync(User)
        : null;
    var currentUserDisplayName = !string.IsNullOrWhiteSpace(currentUser?.FirstName) || !string.IsNullOrWhiteSpace(currentUser?.LastName)
        ? currentUser?.GetFullName()
        : !string.IsNullOrWhiteSpace(currentUser?.DisplayUsername)
            ? currentUser.DisplayUsername
            : currentUser?.GetFullName();
    if (string.IsNullOrWhiteSpace(currentUserDisplayName))
    {
        currentUserDisplayName = User?.Identity?.Name ?? "Llogaria";
    }
    var currentUserAvatar = !string.IsNullOrWhiteSpace(currentUser?.ProfileImageUrl)
        ? currentUser.ProfileImageUrl
        : "/images/default-avatar.png";
    var currentUserNameParts = currentUserDisplayName
        .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    var brandingSettings = await SiteSettings.GetGroupAsync("branding");
    string BrandVal(string key, string def = "") => brandingSettings.TryGetValue(key, out var v) && !string.IsNullOrEmpty(v) ? v : def;
    var analyticsSettings = await SiteSettings.GetGroupAsync("analytics");
    string AnaVal(string key, string def = "") => analyticsSettings.TryGetValue(key, out var v) && !string.IsNullOrEmpty(v) ? v : def;
    var trackingEnabled = AnaVal("EnableTracking", "true") == "true";
    var ga4Id = AnaVal("GA4MeasurementId");
    var gtmId = AnaVal("GTMContainerId");
    var seoSettings = await SiteSettings.GetGroupAsync("seo");
    string SeoVal(string key, string def = "") => seoSettings.TryGetValue(key, out var v) && !string.IsNullOrEmpty(v) ? v : def;
    var siteBaseUrl = SeoVal("SiteBaseUrl", "https://teknosos.app").TrimEnd('/');
    var adsenseSettings = await SiteSettings.GetGroupAsync("adsense");
    string AdsVal(string key, string def = "") => adsenseSettings.TryGetValue(key, out var v) && !string.IsNullOrEmpty(v) ? v : def;
    var adsenseEnabled = AdsVal("Enabled", "false") == "true";
    var adsenseClientId = AdsVal("ClientId");
    var showSubscriptionGlobalNotice = false;
    var subscriptionGlobalNoticeText = string.Empty;

    if (currentUser?.Role == TeknoSOS.WebApp.Domain.Enums.UserRole.Professional)
    {
        var subscriptionEndDate = currentUser.SubscriptionEndDate ?? currentUser.RegistrationDate.AddDays(90);
        var daysRemaining = (int)Math.Ceiling((subscriptionEndDate - DateTime.UtcNow).TotalDays);

        if (daysRemaining <= 3)
        {
            showSubscriptionGlobalNotice = true;
            subscriptionGlobalNoticeText = daysRemaining <= 0
                ? "Abonimi juaj ka skaduar. Shërbimi është ndërprerë automatikisht deri në pagesën e rinovimit."
                : $"Abonimi juaj skadon pas {daysRemaining} ditësh. Ju lutem kryeji pagesën në një nga format e pagesës, pasi shërbimi do të ndërpritet automatikisht.";
        }
    }
}
<!DOCTYPE html>
<html lang="@L.CurrentLanguage" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- SEO Meta Tags -->
    @if (ViewData["Description"] != null)
    {
        <meta name="description" content="@ViewData["Description"]" />
    }
    else
    {
        <meta name="description" content="TeknoSOS - Platforma #1 në Shqipëri për zgjidhjen e defekteve elektrike, hidraulike dhe teknike. Elektricistë të licencuar, riparime urgjente 24/7." />
    }
    <meta name="author" content="@BrandVal("SiteName", "TeknoSOS")" />
    @if (ViewData["Keywords"] != null)
    {
        <meta name="keywords" content="@ViewData["Keywords"]" />
    }
    else
    {
        <meta name="keywords" content="teknosos, defekt elektrik, elektricist Tiranë, riparime elektrike, instalime, hidraulik, teknik, shërbime, Shqipëri, Albania" />
    }
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="googlebot" content="index, follow" />
    <link rel="canonical" href="@siteBaseUrl@Context.Request.Path" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@siteBaseUrl@Context.Request.Path" />
    <meta property="og:title" content="@ViewData["Title"] - @BrandVal("SiteName", "TeknoSOS")" />
    <meta property="og:description" content="@(ViewData["Description"] ?? "TeknoSOS - Platforma #1 në Shqipëri për zgjidhjen e defekteve. Elektricistë dhe teknikë të licencuar.")" />
    <meta property="og:image" content="@siteBaseUrl/images/og-image.jpg" />
    <meta property="og:locale" content="sq_AL" />
    <meta property="og:site_name" content="TeknoSOS" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@ViewData["Title"] - TeknoSOS" />
    <meta name="twitter:description" content="@(ViewData["Description"] ?? "Platforma #1 në Shqipëri për zgjidhjen e defekteve elektrike dhe teknike.")" />
    <meta name="twitter:image" content="@siteBaseUrl/images/og-image.jpg" />
    
    <!-- Geo Tags for Local SEO -->
    <meta name="geo.region" content="AL" />
    <meta name="geo.placename" content="Tiranë, Shqipëri" />
    <meta name="geo.position" content="41.3275;19.8187" />
    <meta name="ICBM" content="41.3275, 19.8187" />
    
    <title>@ViewData["Title"] - @BrandVal("SiteName", "TeknoSOS")</title>
    
    <!-- Preload critical resources -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cdn.jsdelivr.net">
    <link rel="dns-prefetch" href="https://cdnjs.cloudflare.com">
    
    <!-- Preload critical CSS -->
    <link rel="preload" href="~/css/site.css" as="style" asp-append-version="true">
    
    <!-- Google Fonts — Inter with display=swap for fast text rendering -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <!-- Favicon (dynamic from admin settings) -->
    <link rel="icon" href="@BrandVal("FaviconUrl", "/favicon.ico")" />
    <link rel="apple-touch-icon" href="@BrandVal("FaviconUrl", "/favicon.ico")" />

    <!-- Google Tag Manager (dynamic from admin) -->
    @if (trackingEnabled && !string.IsNullOrEmpty(gtmId))
    {
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','@gtmId');</script>
    }
    <!-- End Google Tag Manager -->

    <!-- Google Analytics (dynamic from admin) -->
    @if (trackingEnabled && !string.IsNullOrEmpty(ga4Id))
    {
    <script async src="https://www.googletagmanager.com/gtag/js?id=@ga4Id"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '@ga4Id');
    </script>
    }
    <!-- End Google Analytics -->

    @if (adsenseEnabled && !string.IsNullOrWhiteSpace(adsenseClientId))
    {
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=@adsenseClientId" crossorigin="anonymous"></script>
    }

    <!-- Dark mode forcibly disabled for public site -->
    <script>
        document.documentElement.setAttribute('data-theme', 'light');
        localStorage.setItem('ts-theme', 'light');
    </script>
    @await RenderSectionAsync("Styles", required: false)
</head>
