@model TeknoSOS.WebApp.Models.SendMailViewModel
@{
    ViewBag.Title = "Dërgo Email";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section Scripts {
    <script src="https://cdn.tiny.cloud/1/no-api-key/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>
    <script>
        tinymce.init({
            selector: '#Body',
            menubar: false,
            plugins: 'link lists',
            toolbar: 'undo redo | bold italic underline | bullist numlist | link',
            height: 300
        });
    </script>
}
<h2>Dërgo Email</h2>
@if (ViewBag.Success != null)
{
    <div class="alert alert-success">@ViewBag.Success</div>
}
@using (Html.BeginForm("SendMail", "Admin", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    <div class="form-group">
        @Html.LabelFor(m => m.To)
        @Html.TextBoxFor(m => m.To, new { @class = "form-control", @readonly = "readonly" })
        @Html.ValidationMessageFor(m => m.To)
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.Subject)
        @Html.TextBoxFor(m => m.Subject, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Subject)
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.Body)
        @Html.TextAreaFor(m => m.Body, new { @class = "form-control", id = "Body" })
        @Html.ValidationMessageFor(m => m.Body)
    </div>
    <button type="submit" class="btn btn-primary">Dërgo</button>
}
