@page
@model TeknoSOS.WebApp.Pages.MessagesModel
@{
    ViewData["Title"] = L.T("nav.messages");
    Layout = "/Views/Shared/_Layout.cshtml";
}

<style>
    .messages-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 1rem;
    }

    .messages-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--ts-border);
    }

    .messages-header h1 {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--ts-text);
        margin: 0;
    }

    .conversation-list {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .conversation-item {
        display: flex;
        align-items: stretch;
        background: var(--ts-surface);
        border: 1px solid var(--ts-border);
        border-radius: var(--ts-radius-lg);
        overflow: hidden;
        transition: all var(--ts-transition);
    }

    .conversation-item:hover {
        background: var(--ts-surface-hover);
        border-color: var(--ts-primary);
        transform: translateY(-2px);
        box-shadow: var(--ts-shadow-md);
    }

    .conversation-item.has-unread {
        border-left: 3px solid var(--ts-primary);
    }

    .conversation-main-link {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex: 1;
        min-width: 0;
        padding: 1rem;
        text-decoration: none;
        color: inherit;
    }

    .conversation-profile-link {
        width: 52px;
        min-width: 52px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-left: 1px solid var(--ts-border);
        color: var(--ts-text-muted);
        text-decoration: none;
        transition: all var(--ts-transition);
    }

    .conversation-profile-link:hover {
        background: var(--ts-primary-light);
        color: var(--ts-primary);
    }

    .conversation-avatar {
        position: relative;
        flex-shrink: 0;
    }

    .conversation-avatar .avatar {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--ts-primary), var(--ts-accent));
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1.2rem;
    }

    .conversation-avatar img {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        object-fit: cover;
    }

    .online-indicator {
        position: absolute;
        bottom: 2px;
        right: 2px;
        width: 14px;
        height: 14px;
        background: var(--ts-success);
        border: 3px solid var(--ts-surface);
        border-radius: 50%;
    }

    .conversation-content {
        flex: 1;
        min-width: 0;
    }

    .conversation-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.25rem;
    }

    .conversation-name {
        font-weight: 600;
        color: var(--ts-text);
        font-size: 1rem;
    }

    .conversation-time {
        font-size: 0.75rem;
        color: var(--ts-text-muted);
    }

    .conversation-preview {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
    }

    .conversation-message {
        font-size: 0.875rem;
        color: var(--ts-text-secondary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        flex: 1;
    }

    .conversation-item.has-unread .conversation-message {
        font-weight: 600;
        color: var(--ts-text);
    }

    .unread-badge {
        background: var(--ts-primary);
        color: white;
        font-size: 0.7rem;
        font-weight: 700;
        padding: 0.2rem 0.5rem;
        border-radius: 10px;
        min-width: 20px;
        text-align: center;
    }

    .conversation-defect {
        font-size: 0.75rem;
        color: var(--ts-text-muted);
        margin-top: 0.25rem;
    }

    .conversation-defect i {
        margin-right: 0.25rem;
    }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--ts-text-muted);
    }

    .empty-state i {
        font-size: 4rem;
        margin-bottom: 1rem;
        opacity: 0.5;
    }

    .empty-state h3 {
        font-size: 1.25rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: var(--ts-text);
    }

    .empty-state p {
        margin-bottom: 1.5rem;
    }

    @@media (max-width: 576px) {
        .messages-container {
            padding: 0.75rem;
        }

        .conversation-item {
            padding: 0.75rem;
        }

        .conversation-avatar .avatar,
        .conversation-avatar img {
            width: 48px;
            height: 48px;
            font-size: 1rem;
        }

        .conversation-name {
            font-size: 0.9rem;
        }

        .conversation-message {
            font-size: 0.8rem;
        }
    }
</style>

<div class="messages-container">
    <div class="messages-header">
        <h1><i class="bi bi-chat-dots me-2"></i>@L.T("nav.messages")</h1>
        @if (Model.Conversations.Any())
        {
            <span class="text-muted small">@Model.Conversations.Count biseda</span>
        }
    </div>

    @if (Model.Conversations.Any())
    {
        <div class="conversation-list">
            @foreach (var conv in Model.Conversations)
            {
                var initials = string.Join("", conv.OtherUserName.Split(' ').Where(x => !string.IsNullOrEmpty(x)).Take(2).Select(x => x[0])).ToUpper();
                if (string.IsNullOrEmpty(initials)) initials = "?";
                
                <div class="conversation-item @(conv.UnreadCount > 0 ? "has-unread" : "")">
                    <a href="/Chat/@conv.DefectId" class="conversation-main-link">
                        <div class="conversation-avatar">
                            @if (!string.IsNullOrEmpty(conv.OtherUserAvatar))
                            {
                                <img src="@conv.OtherUserAvatar" alt="@conv.OtherUserName" />
                            }
                            else
                            {
                                <div class="avatar">@initials</div>
                            }
                            @if (conv.IsOnline)
                            {
                                <div class="online-indicator"></div>
                            }
                        </div>
                        <div class="conversation-content">
                            <div class="conversation-header">
                                <span class="conversation-name">@conv.OtherUserName</span>
                                <span class="conversation-time">@FormatDate(conv.LastMessageDate)</span>
                            </div>
                            <div class="conversation-preview">
                                <span class="conversation-message">@conv.LastMessage</span>
                                @if (conv.UnreadCount > 0)
                                {
                                    <span class="unread-badge">@conv.UnreadCount</span>
                                }
                            </div>
                            <div class="conversation-defect">
                                <i class="bi bi-ticket-detailed"></i>@conv.DefectCode - @conv.DefectTitle
                            </div>
                        </div>
                    </a>
                    @if (!string.IsNullOrEmpty(conv.OtherUserProfileUrl))
                    {
                        <a href="@conv.OtherUserProfileUrl" class="conversation-profile-link" title="Shiko profilin e përdoruesit" aria-label="Shiko profilin e @conv.OtherUserName">
                            <i class="bi bi-person-vcard fs-5"></i>
                        </a>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-chat-square-text"></i>
            <h3>Asnjë bisedë</h3>
            <p>Nuk keni asnjë bisedë aktive. Bisedat fillojnë automatikisht kur caktohet një profesionist për defektin tuaj.</p>
            <a href="/DefectList" class="btn btn-primary btn-pill">
                <i class="bi bi-list-check me-2"></i>Shiko Defektet
            </a>
        </div>
    }
</div>

@functions {
    string FormatDate(DateTime date)
    {
        var now = DateTime.UtcNow;
        var diff = now - date;

        if (diff.TotalMinutes < 1)
            return "Tani";
        if (diff.TotalMinutes < 60)
            return $"{(int)diff.TotalMinutes} min";
        if (diff.TotalHours < 24)
            return $"{(int)diff.TotalHours} orë";
        if (diff.TotalDays < 7)
            return $"{(int)diff.TotalDays} ditë";
        
        return date.ToString("dd MMM");
    }
}
