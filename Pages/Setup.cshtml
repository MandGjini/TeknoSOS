@page
@model TeknoSOS.WebApp.Pages.SetupModel
@{
    ViewData["Title"] = "Konfigurimi Fillestar";
    Layout = null;
}
<!DOCTYPE html>
<html lang="sq">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TeknoSOS - Konfigurimi Fillestar</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">
    <style>
        body { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; }
        .setup-card { max-width: 800px; margin: 2rem auto; }
        .step-indicator { display: flex; gap: 1rem; margin-bottom: 2rem; }
        .step-dot { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center;
                    justify-content: center; font-weight: bold; background: #e9ecef; color: #6c757d; }
        .step-dot.active { background: #2563eb; color: white; }
        .step-dot.done { background: #198754; color: white; }
        .step-section { display: none; }
        .step-section.active { display: block; }
    </style>
</head>
<body>
    <div class="container py-4">
        <div class="setup-card">
            <!-- Header -->
            <div class="text-center text-white mb-4">
                <h1 class="fw-bold"><img src="~/images/logo.png" alt="TeknoSOS Logo" style="width:48px;height:48px;" /> TeknoSOS</h1>
                <p class="lead">Konfigurimi Fillestar i Platformes</p>
            </div>

            @if (Model.IsSetupCompleted)
            {
                <div class="card border-0 shadow">
                    <div class="card-body text-center p-5">
                        <i class="bi bi-check-circle text-success" style="font-size: 4rem;"></i>
                        <h3 class="mt-3 fw-bold">Platforma eshte konfiguruar!</h3>
                        <p class="text-muted mb-4">TeknoSOS eshte gati per perdorim. Mund te hyni ne panelin e administrimit ose faqen kryesore.</p>
                        <div class="d-flex gap-3 justify-content-center">
                            <a href="/" class="btn btn-primary btn-lg"><i class="bi bi-house"></i> Faqja Kryesore</a>
                            <a href="/Admin" class="btn btn-outline-primary btn-lg"><i class="bi bi-shield-lock"></i> Admin Panel</a>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <!-- Step Indicators -->
                <div class="d-flex justify-content-center mb-4">
                    <div class="step-indicator">
                        <div class="step-dot active" id="dot1">1</div>
                        <div class="step-dot" id="dot2">2</div>
                        <div class="step-dot" id="dot3">3</div>
                        <div class="step-dot" id="dot4">4</div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger mx-auto" style="max-width: 800px;">
                        <i class="bi bi-exclamation-triangle"></i> @Model.ErrorMessage
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                {
                    <div class="alert alert-success mx-auto" style="max-width: 800px;">
                        <i class="bi bi-check-circle"></i> @Model.SuccessMessage
                    </div>
                }

                <div class="card border-0 shadow">
                    <div class="card-body p-4">

                        <!-- Step 1: Database Check -->
                        <div class="step-section active" id="step1">
                            <h4 class="fw-bold mb-3"><i class="bi bi-database text-primary"></i> Hapi 1: Kontrolli i Databazes</h4>
                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <div class="card @(Model.DbConnected ? "border-success" : "border-danger")">
                                        <div class="card-body">
                                            <h6>
                                                @if (Model.DbConnected)
                                                {
                                                    <i class="bi bi-check-circle text-success"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-x-circle text-danger"></i>
                                                }
                                                Lidhja me Databazen
                                            </h6>
                                            <small class="text-muted">
                                                @(Model.DbConnected ? "Lidhja me databazen eshte funksionale." : "Nuk mund te lidhet me databazen. Kontrolloni connection string.")
                                            </small>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="card border-info">
                                        <div class="card-body">
                                            <h6><i class="bi bi-people text-info"></i> Perdorues ne Sistem</h6>
                                            <small class="text-muted">@Model.UserCount perdorues te regjistruar</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            @if (Model.DbConnected)
                            {
                                <form method="post" asp-page-handler="RunMigrations" class="mb-3">
                                    <button type="submit" class="btn btn-warning">
                                        <i class="bi bi-arrow-repeat"></i> Ekzekuto Migrimet (Update DB)
                                    </button>
                                </form>
                            }
                            <button class="btn btn-primary" onclick="goToStep(2)" @(Model.DbConnected ? "" : "disabled")>
                                Vazhdo <i class="bi bi-arrow-right"></i>
                            </button>
                        </div>

                        <!-- Step 2: Platform Info -->
                        <div class="step-section" id="step2">
                            <h4 class="fw-bold mb-3"><i class="bi bi-building text-primary"></i> Hapi 2: Informacionet e Platformes</h4>
                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Emri i Platformes</label>
                                    <input id="inp_platformName" class="form-control" value="@Model.PlatformName" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Tagline</label>
                                    <input id="inp_tagline" class="form-control" value="@Model.PlatformTagline" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Gjuha Default</label>
                                    <select id="inp_lang" class="form-select">
                                        <option value="sq" selected>AL - Shqip</option>
                                        <option value="en">EN - English</option>
                                        <option value="it">IT - Italiano</option>
                                        <option value="de">DE - Deutsch</option>
                                        <option value="fr">FR - Francais</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Email Kontakti</label>
                                    <input id="inp_contactEmail" class="form-control" value="@Model.ContactEmail" type="email" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Telefoni</label>
                                    <input id="inp_contactPhone" class="form-control" value="@Model.ContactPhone" />
                                </div>
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-secondary" onclick="goToStep(1)"><i class="bi bi-arrow-left"></i> Kthehu</button>
                                <button class="btn btn-primary" onclick="goToStep(3)">Vazhdo <i class="bi bi-arrow-right"></i></button>
                            </div>
                        </div>

                        <!-- Step 3: Admin Account -->
                        <div class="step-section" id="step3">
                            <h4 class="fw-bold mb-3"><i class="bi bi-shield-lock text-primary"></i> Hapi 3: Llogaria e Administratorit</h4>
                            <div class="alert alert-info small">
                                <i class="bi bi-info-circle"></i> Nese llogaria ekziston, ky hap mund te anashkalohet. Llogaria default: admin@teknosos.local / Admin#2024
                            </div>
                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Emri</label>
                                    <input id="inp_firstName" class="form-control" value="@Model.AdminFirstName" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Mbiemri</label>
                                    <input id="inp_lastName" class="form-control" value="@Model.AdminLastName" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Email</label>
                                    <input id="inp_adminEmail" class="form-control" type="email" value="@Model.AdminEmail" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Fjalekalimi (min 6 karaktere)</label>
                                    <input id="inp_adminPassword" class="form-control" type="password" placeholder="Lini bosh per te perdorur llogarite ekzistuese" />
                                </div>
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-secondary" onclick="goToStep(2)"><i class="bi bi-arrow-left"></i> Kthehu</button>
                                <button class="btn btn-primary" onclick="goToStep(4)">Vazhdo <i class="bi bi-arrow-right"></i></button>
                            </div>
                        </div>

                        <!-- Step 4: Confirmation & Execute -->
                        <div class="step-section" id="step4">
                            <h4 class="fw-bold mb-3"><i class="bi bi-check2-all text-primary"></i> Hapi 4: Konfirmo dhe Perfundo</h4>
                            <div class="card bg-light mb-4">
                                <div class="card-body">
                                    <h6 class="fw-bold">Permbledhje e Konfigurimit:</h6>
                                    <ul class="mb-0">
                                        <li>Emri i platformes: <strong id="sum_name">TeknoSOS</strong></li>
                                        <li>Gjuha default: <strong id="sum_lang">sq</strong></li>
                                        <li>Email kontakti: <strong id="sum_contactEmail">info@teknosos.al</strong></li>
                                        <li>Admin email: <strong id="sum_adminEmail">admin@teknosos.local</strong></li>
                                    </ul>
                                </div>
                            </div>
                            <form method="post" asp-page-handler="CompleteSetup" id="setupForm">
                                <input type="hidden" name="PlatformName" id="h_platformName" />
                                <input type="hidden" name="PlatformTagline" id="h_tagline" />
                                <input type="hidden" name="DefaultLanguage" id="h_lang" />
                                <input type="hidden" name="ContactEmail" id="h_contactEmail" />
                                <input type="hidden" name="ContactPhone" id="h_contactPhone" />
                                <input type="hidden" name="AdminEmail" id="h_adminEmail" />
                                <input type="hidden" name="AdminPassword" id="h_adminPassword" />
                                <input type="hidden" name="AdminFirstName" id="h_firstName" />
                                <input type="hidden" name="AdminLastName" id="h_lastName" />
                                <div class="d-flex gap-2">
                                    <button type="button" class="btn btn-secondary" onclick="goToStep(3)"><i class="bi bi-arrow-left"></i> Kthehu</button>
                                    <button type="submit" class="btn btn-success btn-lg" onclick="prepareSubmit()">
                                        <i class="bi bi-rocket-takeoff"></i> Perfundo Konfigurimin
                                    </button>
                                </div>
                            </form>
                        </div>

                    </div>
                </div>
            }

            <p class="text-center text-white-50 small mt-4">TeknoSOS Platform &copy; @DateTime.Now.Year</p>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
            crossorigin="anonymous"></script>
    <script>
        var currentStep = 1;
        function goToStep(n) {
            document.getElementById('step' + currentStep).classList.remove('active');
            document.getElementById('step' + n).classList.add('active');
            for (var i = 1; i <= 4; i++) {
                var dot = document.getElementById('dot' + i);
                dot.classList.remove('active', 'done');
                if (i < n) dot.classList.add('done');
                else if (i === n) dot.classList.add('active');
            }
            currentStep = n;
            if (n === 4) updateSummary();
        }

        function updateSummary() {
            document.getElementById('sum_name').textContent = document.getElementById('inp_platformName').value;
            document.getElementById('sum_lang').textContent = document.getElementById('inp_lang').value;
            document.getElementById('sum_contactEmail').textContent = document.getElementById('inp_contactEmail').value;
            document.getElementById('sum_adminEmail').textContent = document.getElementById('inp_adminEmail').value;
        }

        function prepareSubmit() {
            document.getElementById('h_platformName').value = document.getElementById('inp_platformName').value;
            document.getElementById('h_tagline').value = document.getElementById('inp_tagline').value;
            document.getElementById('h_lang').value = document.getElementById('inp_lang').value;
            document.getElementById('h_contactEmail').value = document.getElementById('inp_contactEmail').value;
            document.getElementById('h_contactPhone').value = document.getElementById('inp_contactPhone').value;
            document.getElementById('h_adminEmail').value = document.getElementById('inp_adminEmail').value;
            document.getElementById('h_adminPassword').value = document.getElementById('inp_adminPassword').value;
            document.getElementById('h_firstName').value = document.getElementById('inp_firstName').value;
            document.getElementById('h_lastName').value = document.getElementById('inp_lastName').value;
        }
    </script>
</body>
</html>
