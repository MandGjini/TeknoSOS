@page
@model TeknoSOS.WebApp.Pages.KarikuesEVModel
@{
    ViewData["Title"] = "Instalim Karikues Makinash Elektrike (EV Charger) Shqipëri | TeknoSOS";
    ViewData["Description"] = "Instalim profesional karikuesish për makina elektrike në Shqipëri. EV Charger për shtëpi dhe biznese. Wallbox, ABB, Schneider. Zgjidhje të plota në Tiranë, Durrës, Vlorë.";
    ViewData["Keywords"] = "charger makine elektrike, EV charger Albania, instalim karikues makinash elektrike, wallbox shqiperi, stacion karikimi, makina elektrike albania, karikues tesla, karikues shtepie";
}

@section Styles {
<style>
    .ev-hero {
        background: linear-gradient(135deg, #065f46 0%, #047857 50%, #065f46 100%);
        padding: 80px 0 60px;
        color: #fff;
        position: relative;
        overflow: hidden;
    }
    .ev-hero::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(16,185,129,0.2) 0%, transparent 70%);
        border-radius: 50%;
    }
    .ev-hero h1 {
        font-size: 2.4rem;
        font-weight: 800;
        margin-bottom: 1rem;
    }
    .ev-hero .lead {
        font-size: 1.15rem;
        opacity: 0.9;
        max-width: 700px;
    }
    .ev-section {
        padding: 60px 0;
    }
    .ev-section:nth-child(even) {
        background: var(--ts-bg-secondary, #f8fafc);
    }
    .ev-service-card {
        background: var(--ts-card-bg, #fff);
        border-radius: 20px;
        padding: 32px;
        height: 100%;
        border: 1px solid var(--ts-border, #e2e8f0);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }
    .ev-service-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, #10b981 0%, #059669 100%);
    }
    .ev-service-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 16px 48px rgba(0,0,0,0.12);
    }
    .ev-icon {
        width: 64px;
        height: 64px;
        border-radius: 16px;
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.75rem;
        margin-bottom: 20px;
    }
    .ev-service-card h3 {
        font-size: 1.25rem;
        font-weight: 700;
        margin-bottom: 14px;
        color: var(--ts-text, #1e293b);
    }
    .check-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .check-list li {
        padding: 8px 0;
        padding-left: 28px;
        position: relative;
        color: var(--ts-text-muted, #64748b);
    }
    .check-list li::before {
        content: '✓';
        position: absolute;
        left: 0;
        color: #10b981;
        font-weight: bold;
    }
    .brand-logo {
        width: 100px;
        height: 60px;
        background: var(--ts-card-bg, #fff);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--ts-border, #e2e8f0);
        font-weight: 700;
        color: var(--ts-text-muted, #64748b);
        font-size: 0.85rem;
    }
    .pricing-card {
        background: var(--ts-card-bg, #fff);
        border-radius: 20px;
        padding: 32px;
        border: 2px solid var(--ts-border, #e2e8f0);
        text-align: center;
        transition: all 0.3s ease;
    }
    .pricing-card.featured {
        border-color: #10b981;
        transform: scale(1.02);
        box-shadow: 0 20px 60px rgba(16,185,129,0.15);
    }
    .pricing-card .price {
        font-size: 2.5rem;
        font-weight: 800;
        color: #10b981;
    }
    .pricing-card .price span {
        font-size: 1rem;
        font-weight: 400;
        color: var(--ts-text-muted);
    }
    .ev-cta {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        border-radius: 24px;
        padding: 48px;
        color: #fff;
        text-align: center;
    }
    .step-number {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: #10b981;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1.25rem;
        flex-shrink: 0;
    }
    .car-badge {
        display: inline-block;
        padding: 6px 14px;
        background: rgba(16,185,129,0.1);
        color: #059669;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        margin: 4px;
        border: 1px solid rgba(16,185,129,0.2);
    }
</style>
}

