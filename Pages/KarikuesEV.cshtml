</section>

<!-- Shërbimet EV -->
<section class="ev-section">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold mb-3">Shërbime Karikuesish për Makina Elektrike</h2>
            <p class="text-muted mx-auto" style="max-width: 600px;">
                Nga instalimi bazë deri te zgjidhjet komerciale — kemi ekspertizën për çdo nevojë
            </p>
        </div>
        <div class="row g-4">
