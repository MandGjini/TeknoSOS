@page
@model TeknoSOS.WebApp.Pages.Account.ProfileModel
@{
    ViewData["Title"] = "Profili Im";

    string CapitalizeInitial(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var trimmed = value.Trim();
        return trimmed.Length == 1 ? trimmed.ToUpper() : char.ToUpper(trimmed[0]) + trimmed[1..];
    }

    var displayFirstName = CapitalizeInitial(Model.CurrentUser?.FirstName);
    var displayLastName = CapitalizeInitial(Model.CurrentUser?.LastName);
}

<div class="container py-4">
    <div class="row">
        <div class="col-lg-4 mb-4">
            <!-- Profile Card -->
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="mb-3">
                        @if (!string.IsNullOrWhiteSpace(Model.CurrentUser?.ProfileImageUrl))
                        {
                            <img src="@Model.CurrentUser.ProfileImageUrl" alt="@Model.CurrentUser.GetFullName()" class="rounded-circle shadow-sm" style="width: 100px; height: 100px; object-fit: cover;" onerror="this.onerror=null;this.src='/images/default-avatar.png';" />
                        }
                        else
                        {
                            <div class="rounded-circle d-inline-flex align-items-center justify-content-center" 
                                 style="width: 100px; height: 100px; background: linear-gradient(135deg, var(--ts-primary), var(--ts-accent));">
                                <i class="bi bi-person text-white" style="font-size: 3rem;"></i>
                            </div>
                        }
                    </div>
                    <h4 class="fw-bold mb-1">@displayFirstName @displayLastName</h4>
                    <p class="text-muted mb-2">@Model.CurrentUser?.Email</p>
                    <span class="badge bg-primary">@Model.CurrentUser?.Role.ToString()</span>
                    <div class="mt-3">
                        @if (Model.CurrentUser?.Role == TeknoSOS.WebApp.Domain.Enums.UserRole.Professional)
                        {
                            <a asp-page="/TechnicianProfile" asp-route-id="@(Model.CurrentUser.DisplayUsername ?? Model.CurrentUser.Id)" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-eye me-1"></i>Shiko profilin publik
                            </a>
                        }
                        else if (Model.CurrentUser != null)
                        {
                            <a asp-page="/UserProfile" asp-route-id="@(Model.CurrentUser.DisplayUsername ?? Model.CurrentUser.Id)" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-eye me-1"></i>Shiko profilin publik
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-lg-8">
            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="bi bi-check-circle"></i> @Model.SuccessMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    <i class="bi bi-exclamation-triangle"></i> @Model.ErrorMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- Review Total & CV Galeri -->
            <div class="row mb-4">
                <div class="col-md-6 mb-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center">
                            <h5 class="mb-2"><i class="bi bi-star-half text-warning"></i> Review Total</h5>
                            <div class="display-6 fw-bold">@(Model.CurrentUser?.AverageRating ?? 0) <span class="fs-6 text-muted">(@Model.CurrentUser?.TotalReviews review)</span></div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center">
                            <h5 class="mb-2"><i class="bi bi-images text-primary"></i> CV Galeri</h5>
                            <div class="mb-2 text-muted small">Punët e tua të realizuara</div>
                            <div class="d-flex flex-wrap justify-content-center gap-2">
                                <!-- Placeholder për galeri, mund të zëvendësohet me imazhe reale -->
                                <div class="border rounded bg-light p-2">Nuk ka punë të ngarkuara ende</div>
                            </div>
                            <a href="#" class="btn btn-outline-primary btn-sm mt-2 disabled">Ngarko punë të re (së shpejti)</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Personal Info -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-person text-primary"></i> Informacioni Personal</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="UpdateProfile">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Emri</label>
                                <input type="text" name="firstName" class="form-control" value="@Model.CurrentUser?.FirstName" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Mbiemri</label>
                                <input type="text" name="lastName" class="form-control" value="@Model.CurrentUser?.LastName" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Email</label>
                                <input type="email" class="form-control" value="@Model.CurrentUser?.Email" disabled />
                                <small class="text-muted">Email nuk mund të ndryshohet</small>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Telefoni</label>
                                <input type="tel" name="phoneNumber" class="form-control" value="@Model.CurrentUser?.PhoneNumber" />
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">Adresa</label>
                                <input type="text" name="address" class="form-control" value="@Model.CurrentUser?.Address" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Qyteti</label>
                                <input type="text" name="city" class="form-control" value="@Model.CurrentUser?.City" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Kodi Postar</label>
                                <input type="text" name="postalCode" class="form-control" value="@Model.CurrentUser?.PostalCode" />
                            </div>
                        </div>
                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg"></i> Ruaj Ndryshimet
                            </button>
                            <a href="#certificates" class="btn btn-outline-primary">Menaxho Certifikatat</a>
                            <a href="#changepassword" class="btn btn-outline-warning">Ndrysho Fjalëkalimin</a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Professional Info (only for professionals) -->
            @if (Model.CurrentUser?.Role == TeknoSOS.WebApp.Domain.Enums.UserRole.Professional)
            {
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <h5 class="mb-0"><i class="bi bi-briefcase text-primary"></i> Informacioni Profesional</h5>
                    </div>
                    <div class="card-body">
                        <form method="post" asp-page-handler="UpdateProfessionalInfo">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Emri i Kompanisë</label>
                                    <input type="text" name="companyName" class="form-control" value="@Model.CurrentUser?.CompanyName" placeholder="p.sh. FixAll Tirana" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Vitet e Përvojës</label>
                                    <input type="number" name="yearsOfExperience" class="form-control" value="@Model.CurrentUser?.YearsOfExperience" min="0" max="50" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-semibold">Përshkrimi / Bio</label>
                                    <textarea name="bio" class="form-control" rows="4" placeholder="Përshkruani përvojën dhe shërbimet tuaja...">@Model.CurrentUser?.Bio</textarea>
                                    <small class="text-muted">Ky tekst do të shfaqet në profilin tuaj publik</small>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Rrezja e Shërbimit (km)</label>
                                    <input type="number" name="serviceRadiusKm" class="form-control" value="@Model.CurrentUser?.ServiceRadiusKm" min="1" max="200" />
                                    <small class="text-muted">Sa larg jeni i gatshëm të udhëtoni për punë</small>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Disponueshmëria</label>
                                    <div class="form-check form-switch mt-2">
                                        <input class="form-check-input" type="checkbox" name="isAvailable" id="isAvailable" @(Model.CurrentUser?.IsAvailableForWork == true ? "checked" : "") />
                                        <label class="form-check-label" for="isAvailable">I disponueshëm për punë të reja</label>
                                    </div>
                                </div>
                            </div>
                            <div class="mt-4">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check-lg"></i> Ruaj Informacionin Profesional
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            }

            <!-- Change Password (anchor) -->
            <div id="changepassword" class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-shield-lock text-primary"></i> Ndrysho Fjalëkalimin</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="ChangePassword">
                        <div class="row g-3">
                            <div class="col-md-12">
                                <label class="form-label fw-semibold">Fjalëkalimi Aktual</label>
                                <input type="password" name="currentPassword" class="form-control" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Fjalëkalimi i Ri</label>
                                <input type="password" name="newPassword" class="form-control" required minlength="6" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Konfirmo Fjalëkalimin</label>
                                <input type="password" name="confirmPassword" class="form-control" required minlength="6" />
                            </div>
                        </div>
                        <div class="mt-4">
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-key"></i> Ndrysho Fjalëkalimin
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Danger Zone -->
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Zona e Rrezikshme</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-3">Fshirja e llogarisë është e përhershme dhe nuk mund të kthehet mbrapa.</p>
                    <form method="post" asp-page-handler="DeleteAccount" onsubmit="return confirm('A jeni të sigurt që dëshironi të fshini llogarinë? Kjo veprim nuk mund të kthehet!');">
                        <button type="submit" class="btn btn-outline-danger">
                            <i class="bi bi-trash"></i> Fshi Llogarinë
                        </button>
                    </form>
                </div>
            </div>

            <!-- Certifikatat & Foto (anchor) -->
            <div id="certificates" class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-award text-primary"></i> Certifikatat & Foto</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <b>Certifikatat e ngarkuara:</b> <span class="badge bg-primary">@(Model.CurrentUser?.Certificates?.Count ?? 0)</span>
                    </div>
                    <div class="row g-3">
                        @if (Model.CurrentUser?.Certificates != null && Model.CurrentUser.Certificates.Any())
                        {
                            @foreach (var cert in Model.CurrentUser.Certificates)
                            {
                                <div class="col-md-6 col-lg-4">
                                    <div class="card h-100 border @(cert.IsVerified ? "border-success" : "border-warning")">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <h6 class="fw-bold mb-0">@cert.Title</h6>
                                                @if (cert.IsVerified)
                                                {
                                                    <span class="badge bg-success"><i class="bi bi-check-circle"></i> Verifikuar</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning text-dark"><i class="bi bi-clock"></i> Në pritje</span>
                                                }
                                            </div>
                                            @if (!string.IsNullOrEmpty(cert.IssuedBy))
                                            {
                                                <p class="small text-muted mb-1"><i class="bi bi-building"></i> @cert.IssuedBy</p>
                                            }
                                            @if (!string.IsNullOrEmpty(cert.CertificateNumber))
                                            {
                                                <p class="small text-muted mb-1"><i class="bi bi-hash"></i> @cert.CertificateNumber</p>
                                            }
                                            @if (cert.IssueDate.HasValue)
                                            {
                                                <p class="small text-muted mb-1"><i class="bi bi-calendar"></i> Lëshuar: @cert.IssueDate.Value.ToString("dd/MM/yyyy")</p>
                                            }
                                            @if (cert.ExpiryDate.HasValue)
                                            {
                                                var isExpired = cert.ExpiryDate.Value < DateTime.Now;
                                                <p class="small @(isExpired ? "text-danger" : "text-muted") mb-1">
                                                    <i class="bi bi-calendar-x"></i> 
                                                    Skadon: @cert.ExpiryDate.Value.ToString("dd/MM/yyyy")
                                                    @if (isExpired)
                                                    {
                                                        <span class="badge bg-danger ms-1">Skaduar</span>
                                                    }
                                                </p>
                                            }
                                            <div class="mt-3 d-flex gap-2">
                                                @if (!string.IsNullOrEmpty(cert.DocumentUrl))
                                                {
                                                    <a href="@cert.DocumentUrl" target="_blank" class="btn btn-sm btn-outline-primary">
                                                        <i class="bi bi-eye"></i> Shiko
                                                    </a>
                                                }
                                                <!-- Fshirja e certifikatës mund të implementohet këtu nëse duhet -->
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="bi bi-file-earmark-x text-muted" style="font-size: 4rem;"></i>
                                <h5 class="mt-3 text-muted">Nuk keni ngarkuar asnjë certifikatë ende</h5>
                                <p class="text-muted">Ngarkoni certifikatat tuaja profesionale për t'u verifikuar</p>
                            </div>
                        }
                    </div>
                    <!-- Upload Certificate Form (shfaq vetëm për professional) -->
                    @if (Model.CurrentUser?.Role == TeknoSOS.WebApp.Domain.Enums.UserRole.Professional)
                    {
                        <form method="post" asp-page-handler="UploadCertificate" enctype="multipart/form-data" class="mt-4">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Titulli i Certifikatës *</label>
                                    <input type="text" name="title" class="form-control" placeholder="p.sh. Elektricist i Licensuar" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Lëshuar Nga</label>
                                    <input type="text" name="issuedBy" class="form-control" placeholder="p.sh. Ministria e Arsimit" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Numri i Certifikatës</label>
                                    <input type="text" name="certificateNumber" class="form-control" placeholder="p.sh. CERT-2024-12345" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Data e Lëshimit</label>
                                    <input type="date" name="issueDate" class="form-control" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Data e Skadimit (Opsionale)</label>
                                    <input type="date" name="expiryDate" class="form-control" />
                                    <small class="text-muted">Lëre bosh nëse nuk ka skadim</small>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Dokumenti/Foto *</label>
                                    <input type="file" name="certificateFile" class="form-control" accept="image/jpeg,image/png,image/webp,application/pdf" required />
                                    <small class="text-muted">JPG, PNG, WebP ose PDF, max 10MB</small>
                                </div>
                            </div>
                            <div class="mt-4">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-upload"></i> Ngarko Certifikatën
                                </button>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
