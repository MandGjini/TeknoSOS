@page
@model FAQModel
@{
    ViewData["Title"] = await CMS.GetContentAsync("faq", "hero_title");
}

<!-- Hero Banner -->
<section class="hero text-white py-5 mb-5 rounded-3 shadow">
    <div class="container py-5 text-center">
        <h1 class="display-4 fw-bold mb-3">@await CMS.GetContentAsync("faq", "hero_title")</h1>
        <p class="lead mb-0 opacity-75">@await CMS.GetContentAsync("faq", "hero_subtitle")</p>
    </div>
</section>

<!-- FAQ Accordion -->
<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="accordion" id="faqAccordion">
            @{ var faqIndex = 0; }
            @foreach (var item in Model.FAQItems.OrderBy(f => f.SortOrder))
            {
                faqIndex++;
                var headingId = $"faqHeading{faqIndex}";
                var collapseId = $"faqCollapse{faqIndex}";
                <div class="accordion-item border-0 shadow-sm mb-3 rounded-3 overflow-hidden">
                    <h2 class="accordion-header" id="@headingId">
                        <button class="accordion-button @(faqIndex > 1 ? "collapsed" : "") fw-semibold" type="button"
                                data-bs-toggle="collapse" data-bs-target="#@collapseId"
                                aria-expanded="@(faqIndex == 1 ? "true" : "false")" aria-controls="@collapseId">
                            <i class="bi bi-question-circle text-primary me-2"></i> @item.Title
                        </button>
                    </h2>
                    <div id="@collapseId" class="accordion-collapse collapse @(faqIndex == 1 ? "show" : "")"
                         aria-labelledby="@headingId" data-bs-parent="#faqAccordion">
                        <div class="accordion-body text-muted lh-lg">
                            @Html.Raw(item.Content)
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Contact CTA -->
        <div class="text-center mt-5 p-5 bg-light rounded-3 shadow-sm">
            <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 56px; height: 56px;">
                <i class="bi bi-chat-dots text-primary fs-4"></i>
            </div>
            <h5 class="fw-bold mb-2">@await CMS.GetContentAsync("faq", "contact_title")</h5>
            <p class="text-muted mb-3">@await CMS.GetContentAsync("faq", "contact_text")</p>
            <a asp-page="/Contact" class="btn btn-primary rounded-pill px-4">
                <i class="bi bi-envelope me-1"></i> @await CMS.GetContentAsync("faq", "contact_button")
            </a>
        </div>
    </div>
</div>
