@page
@model TeknoSOS.WebApp.Pages.DefekteElektrikeModel
@{
    ViewData["Title"] = "Defekte Elektrike - Elektricist i Licencuar Tiranë | TeknoSOS";
    ViewData["Description"] = "Zgjidhje profesionale për defekte elektrike në Shqipëri. Elektricistë të licencuar për qark të shkurtër, automat të rënë, priza të djegura. Riparime urgjente 24/7 në Tiranë, Durrës, Vlorë.";
    ViewData["Keywords"] = "defekt elektrik, elektricist Tiranë, riparime elektrike urgjente, instalime elektrike, elektricist i licencuar, qark i shkurtër, automat elektrik, priza e djegur, kabllo elektrike";
}

@section Styles {
<style>
    .seo-hero {
        background: linear-gradient(135deg, #0B2545 0%, #13315C 50%, #0B2545 100%);
        padding: 80px 0 60px;
        color: #fff;
        position: relative;
        overflow: hidden;
    }
    .seo-hero::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(242,140,40,0.15) 0%, transparent 70%);
        border-radius: 50%;
    }
    .seo-hero h1 {
        font-size: 2.5rem;
        font-weight: 800;
        margin-bottom: 1rem;
    }
    .seo-hero .lead {
        font-size: 1.15rem;
        opacity: 0.9;
        max-width: 700px;
    }
    .seo-section {
        padding: 60px 0;
    }
    .seo-section:nth-child(even) {
        background: var(--ts-bg-secondary, #f8fafc);
    }
    .defect-card {
        background: var(--ts-card-bg, #fff);
        border-radius: 16px;
        padding: 24px;
        height: 100%;
        border: 1px solid var(--ts-border, #e2e8f0);
        transition: all 0.3s ease;
    }
    .defect-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 40px rgba(0,0,0,0.1);
    }
    .defect-icon {
        width: 56px;
        height: 56px;
        border-radius: 12px;
        background: linear-gradient(135deg, #F28C28 0%, #e07b1a 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.5rem;
        margin-bottom: 16px;
    }
    .defect-card h3 {
        font-size: 1.15rem;
        font-weight: 700;
        margin-bottom: 12px;
        color: var(--ts-text, #1e293b);
    }
    .defect-card p {
        font-size: 0.92rem;
        color: var(--ts-text-muted, #64748b);
        margin-bottom: 0;
    }
    .city-badge {
        display: inline-block;
        padding: 8px 16px;
        background: var(--ts-primary, #0B2545);
        color: #fff;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        margin: 4px;
    }
    .price-table {
        background: var(--ts-card-bg, #fff);
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid var(--ts-border, #e2e8f0);
    }
    .price-table th {
        background: var(--ts-primary, #0B2545);
        color: #fff;
        font-weight: 600;
        padding: 16px;
    }
    .price-table td {
        padding: 14px 16px;
        border-bottom: 1px solid var(--ts-border, #e2e8f0);
    }
    .cta-box {
        background: linear-gradient(135deg, #F28C28 0%, #e07b1a 100%);
        border-radius: 20px;
        padding: 40px;
        color: #fff;
        text-align: center;
    }
    .cta-box h3 {
        font-size: 1.75rem;
        font-weight: 800;
        margin-bottom: 16px;
    }
    .trust-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 20px;
        background: rgba(255,255,255,0.1);
        border-radius: 30px;
        font-size: 0.9rem;
        margin: 6px;
    }
    .trust-badge i {
        color: #F28C28;
    }
</style>
}

<!-- JSON-LD Structured Data -->
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "LocalBusiness",
    "name": "TeknoSOS - Shërbime Elektrike",
    "description": "Platforma #1 në Shqipëri për zgjidhjen e defekteve elektrike. Elektricistë të licencuar për riparime urgjente.",
    "url": "https://teknosos.app/DefekteElektrike",
    "telephone": "+355-69-000-0000",
    "address": {
        "@@type": "PostalAddress",
        "addressLocality": "Tiranë",
        "addressRegion": "Tiranë",
        "addressCountry": "AL"
    },
    "geo": {
        "@@type": "GeoCoordinates",
        "latitude": "41.3275",
        "longitude": "19.8187"
    },
    "areaServed": ["Tiranë", "Durrës", "Vlorë", "Shkodër", "Elbasan", "Korçë"],
    "serviceType": ["Riparime Elektrike", "Instalime Elektrike", "Emergjenca Elektrike"],
    "priceRange": "$$",
    "openingHours": "Mo-Su 00:00-24:00"
}
</script>

<!-- Breadcrumb Schema -->
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "BreadcrumbList",
    "itemListElement": [
        {"@@type": "ListItem", "position": 1, "name": "Kryefaqja", "item": "https://teknosos.app/"},
        {"@@type": "ListItem", "position": 2, "name": "Defekte Elektrike", "item": "https://teknosos.app/DefekteElektrike"}
    ]
}
</script>

<!-- Hero Section -->
<section class="seo-hero">
    <div class="container">
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb" style="background:transparent; padding:0; margin:0;">
                <li class="breadcrumb-item"><a href="/" class="text-white-50">Kryefaqja</a></li>
                <li class="breadcrumb-item active text-white">Defekte Elektrike</li>
            </ol>
        </nav>
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h1>Defekte Elektrike? Zgjidhje Profesionale Brenda Minutash</h1>
                <p class="lead">
                    TeknoSOS është platforma më e avancuar në Shqipëri që lidh qytetarët me <strong>elektricistë të licencuar</strong> 
                    për çdo emergjencë elektrike. Nga një qark i shkurtër deri te zëvendësimi i automatëve — ne kemi zgjidhjen.
                </p>
                <div class="d-flex flex-wrap gap-2 mt-4">
                    <span class="trust-badge"><i class="bi bi-patch-check-fill"></i> Elektricistë të Verifikuar</span>
                    <span class="trust-badge"><i class="bi bi-lightning-charge-fill"></i> Përgjigje Brenda 30 Min</span>
                    <span class="trust-badge"><i class="bi bi-shield-check"></i> Garanci Pune</span>
                </div>
                <div class="mt-4">
                    <a asp-page="/ReportDefect" class="btn btn-warning btn-lg px-4 me-2">
                        <i class="bi bi-lightning-charge me-2"></i>Raporto Defekt Tani
                    </a>
                    <a asp-page="/Technicians" class="btn btn-outline-light btn-lg px-4">
                        <i class="bi bi-people me-2"></i>Shiko Elektricistët
                    </a>
                </div>
            </div>
            <div class="col-lg-4 d-none d-lg-block text-center">
                <i class="bi bi-lightning-charge-fill" style="font-size: 180px; opacity: 0.15;"></i>
            </div>
        </div>
    </div>
</section>

<!-- Defekte të Zakonshme -->
<section class="seo-section">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold mb-3">Defekte Elektrike të Zakonshme në Shqipëri</h2>
            <p class="text-muted mx-auto" style="max-width: 600px;">
                Rrjeti elektrik dhe instalimet e vjetra krijojnë probleme të vazhdueshme. Këto janë defektet që zgjidhim çdo ditë:
            </p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-4">
                <div class="defect-card">
                    <div class="defect-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
                    <h3>Qark i Shkurtër (Short Circuit)</h3>
                    <p>Kur rryma kalon rrugën e gabuar, rreziku për zjarr është real. Shenjat: era e djegur plastike, automati që bie vazhdimisht, priza që nxehet. <strong>Mos e injoroni – telefononi menjëherë.</strong></p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="defect-card">
                    <div class="defect-icon"><i class="bi bi-toggle-off"></i></div>
                    <h3>Automat që Bie Shpesh</h3>
                    <p>Nëse automati juaj bie pa arsye të dukshme, keni: mbingarkesë në qark, kabllo të dëmtuara, ose pajisje me defekt. Një elektricist profesionist identifikon shkakun brenda minutash.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="defect-card">
                    <div class="defect-icon"><i class="bi bi-plug-fill"></i></div>
                    <h3>Priza dhe Çelësa të Djegur</h3>
                    <p>Prizat e zeza ose të shkrira janë alarm i kuq. Shkaqet: lidhje të dobëta, kabllo nën-dimensionuara, ngarkesë e tepërt. Zëvendësimi urgjent parandalon zjarrin.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="defect-card">
                    <div class="defect-icon"><i class="bi bi-lightbulb-fill"></i></div>
                    <h3>Ndriçim LED që Dridhet</h3>
                    <p>Llambat LED që dridhen tregojnë: problem me tensionin, ballast/driver të dëmtuar, ose lidhje jo të sigurta. Diagnostifikimi profesional zbulon shkakun.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="defect-card">
                    <div class="defect-icon"><i class="bi bi-cable-car"></i></div>
                    <h3>Kabllo të Vjetra Alumini</h3>
                    <p>Shumë ndërtesa në Shqipëri kanë ende kabllo alumini nga koha e komunizmit. Nxehen më shumë se bakri dhe rrisin rrezikun për zjarr. <strong>Rekomandim: zëvendësim i plotë.</strong></p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="defect-card">
                    <div class="defect-icon"><i class="bi bi-shield-x"></i></div>
                    <h3>Mungesa e Tokëzimit</h3>
                    <p>Pa tokëzim të duhur, çdo defekt bëhet rrezik për jetën. Ne instalojmë sisteme tokëzimi sipas standardeve europiane për sigurinë maksimale.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Si Funksionon -->
<section class="seo-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
