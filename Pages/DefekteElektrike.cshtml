            <i class="bi bi-lightning-charge me-2"></i>Raporto Defekt
        </a>
        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-light btn-lg px-5">
            <i class="bi bi-person-plus me-2"></i>Regjistrohu Falas
        </a>
    </div>
</section>
