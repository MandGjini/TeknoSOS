                <div class="d-flex mb-4">
                    <div class="me-3">
                        <span class="badge bg-primary rounded-circle p-3 fs-5">1</span>
                    </div>
                    <div>
                        <h5 class="fw-bold">Raportoni Defektin</h5>
                        <p class="text-muted mb-0">Përshkruani problemin me foto dhe lokacion. Merr vetëm 2 minuta.</p>
                    </div>
                </div>
                <div class="d-flex mb-4">
                    <div class="me-3">
                        <span class="badge bg-primary rounded-circle p-3 fs-5">2</span>
                    </div>
                    <div>
