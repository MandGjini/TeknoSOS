    </div>
</section>

<!-- Why Choose Us -->
<section class="section-2026" style="background: var(--ts-bg-secondary);">
    <div class="container">
        <div class="section-header text-center fade-up">
            <div class="section-badge"><i class="bi bi-shield-check"></i> @L.T("common.advantages")</div>
            <h2>@await CMS.GetContentAsync("home", "why_title")</h2>
            <p class="section-desc mx-auto">@await CMS.GetContentAsync("home", "why_subtitle")</p>
        </div>
        <div class="row g-4">
            @foreach (var item in Model.WhyUs)
            {
                <div class="col-md-6 fade-up">
                    <div class="feature-card">
                        <div class="feature-icon" style="background: var(--ts-primary-light); color: var(--ts-primary);">
                            <i class="bi @(item.IconClass ?? "bi-check-lg")"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-1" style="font-size: 1rem;">@item.Title</h5>
                            <p class="mb-0" style="font-size: 0.88rem;">@item.Content</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- How It Works Steps -->
<section class="section-2026" style="background: var(--ts-bg);">
    <div class="container">
        <div class="section-header text-center fade-up">
            <div class="section-badge"><i class="bi bi-signpost-split"></i> Process</div>
            <h2>@await CMS.GetContentAsync("home", "steps_title")</h2>
        </div>
        <div class="row g-4">
            @{ var stepIndex = 1; }
            @foreach (var step in Model.Steps)
            {
                <div class="col-md-6 col-lg-3 fade-up">
                    <div class="step-card">
                        @if (stepIndex < Model.Steps.Count())
                        {
                            <div class="step-connector d-none d-lg-block"></div>
                        }
                        <div class="step-number">@stepIndex</div>
                        <h5 class="fw-bold" style="font-size: 1rem;">@step.Title</h5>
                        <p style="font-size: 0.85rem;">@step.Content</p>
                    </div>
                </div>
                stepIndex++;
            }
        </div>
    </div>
</section>

<!-- Statistics Banner -->
<section class="section-2026" style="background: var(--ts-bg);">
    <div class="container">
        <div class="stats-banner fade-up">
            <div class="row g-4 text-center">
                @foreach (var stat in Model.Stats)
                {
                    <div class="col-md-3 col-6">
                        <div class="stat-item">
                            <div class="stat-value">@stat.Title</div>
                            <div class="stat-label">@stat.Content</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<!-- For Professionals -->
<section class="section-2026" style="background: var(--ts-bg);">
    <div class="container">
        <div class="cta-2026">
            <div class="row align-items-center">
