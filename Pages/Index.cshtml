                                <i class="bi bi-people-fill text-info mb-3" style="font-size: 2rem;"></i>
                                <h5 class="text-white fw-bold mb-2">Elektricistë</h5>
                                <p class="mb-0 small" style="color: rgba(255,255,255,0.7);">Tiranë, Durrës, Vlorë</p>
