@page
@model TeknoSOS.WebApp.Pages.IndexModel
@{
    ViewData["Title"] = "TeknoSOS - Platforma #1 për Defekte Elektrike në Shqipëri";
    ViewData["Description"] = "TeknoSOS - Zgjidhni defekte elektrike, hidraulike dhe teknike me elektricistë të licencuar. Riparime urgjente 24/7 në Tiranë, Durrës, Vlorë. Instalim karikuesish EV.";
    ViewData["Keywords"] = "teknosos, defekt elektrik, elektricist Tiranë, riparime elektrike, instalime elektrike, hidraulik, teknik, charger makine elektrike, EV charger Albania, shërbime teknike Shqipëri";
}

<!-- Hero Section — 2026 Dark Gradient -->
<section class="hero-2026">
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <div class="hero-badge mb-3 fade-up">
                    <i class="bi bi-lightning-charge-fill"></i> @L.T("common.verified") · @L.T("common.fast")
                </div>
                <h1 class="fade-up">
                    @await CMS.GetContentAsync("home", "hero_title")
                </h1>
                <p class="hero-subtitle mt-3 mb-4 fade-up">
                    @await CMS.GetContentAsync("home", "hero_subtitle")
                </p>
                @if (User?.Identity?.IsAuthenticated ?? false)
                {
                    <div class="d-flex flex-wrap gap-3 fade-up">
                        <a asp-page="/ReportDefect" class="btn btn-primary btn-lg btn-pill">
                            <i class="bi bi-plus-circle me-2"></i> @await CMS.GetContentAsync("home", "hero_cta_primary")
                        </a>
                        <a asp-page="/Dashboard" class="btn btn-outline-light btn-lg btn-pill">
                            <i class="bi bi-speedometer2 me-2"></i> @L.T("nav.dashboard")
                        </a>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-wrap gap-3 fade-up">
                        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary btn-lg btn-pill">
                            <i class="bi bi-person-plus me-2"></i> @await CMS.GetContentAsync("home", "cta_button")
                        </a>
                        <a asp-page="/HowItWorks" class="btn btn-outline-light btn-lg btn-pill">
                            <i class="bi bi-play-circle me-2"></i> @await CMS.GetContentAsync("home", "hero_cta_secondary")
                        </a>
                    </div>
                }
                <div class="hero-stats fade-up">
                    @foreach (var stat in Model.Stats.Take(3))
                    {
                        <div class="hero-stat-item">
                            <div class="hero-stat-value">@stat.Title</div>
                            <div class="hero-stat-label">@stat.Content</div>
                        </div>
                    }
                </div>
            </div>
            <div class="col-lg-5 d-none d-lg-block text-center">
                @{
                    var heroBlock = await CMS.GetBlockAsync("home", "hero_image");
                    var heroImg = heroBlock?.ImageUrl ?? "/images/hero_image.jpg";
                }
                <img src="@heroImg" alt="TeknoSOS" class="img-fluid" loading="lazy" style="max-height: 420px; object-fit: cover; border-radius: var(--ts-radius-xl); border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 20px 60px rgba(0,0,0,0.3);"
                     onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                <div style="display:none; height:350px;" class="align-items-center justify-content-center rounded-4 glass-effect p-0 overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1581092918056-0c4c3acd3789?auto=format&fit=crop&w=1200&q=80"
                         alt="Shërbime teknike"
                         class="img-fluid w-100 h-100"
                         style="object-fit: cover;"
                         loading="lazy"
                         referrerpolicy="no-referrer"
                         onerror="this.style.display='none'; this.parentElement.innerHTML='<div class=\'text-center p-5\'><i class=\'bi bi-tools\' style=\'font-size:64px;color:rgba(255,255,255,0.35);\'></i><p class=\'text-white mt-3\' style=\'opacity:0.5;font-size:0.85rem;\'>TeknoSOS Platform</p></div>'">
                </div>
            </div>
        </div>
    </div>
</section>

@await Html.PartialAsync("_BannersPartial", new ViewDataDictionary(ViewData) { { "Position", "inline" }, { "PageKey", HttpContext.Request.Path.Value ?? "/" }, { "CssClass", "container" } })

<!-- Service Categories -->
<section class="section-2026" style="background: var(--ts-bg);">
    <div class="container">
        <div class="section-header text-center fade-up">
            <div class="section-badge"><i class="bi bi-grid-3x3-gap"></i> @L.T("common.services")</div>
            <h2>@await CMS.GetContentAsync("home", "categories_title")</h2>
            <p class="section-desc mx-auto">@await CMS.GetContentAsync("home", "categories_subtitle")</p>
        </div>
        <div class="row g-4">
            @foreach (var cat in Model.Categories)
            {
                <div class="col-md-6 col-lg-4 fade-up">
                    <div class="service-card">
                        @if (!string.IsNullOrEmpty(cat.IconClass))
                        {
                            <div class="service-icon" style="background: var(--ts-primary-light); color: var(--ts-primary);">
                                <i class="bi @cat.IconClass"></i>
                            </div>
                        }
                        <h5>@cat.Title</h5>
                        <p>@cat.Content</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

