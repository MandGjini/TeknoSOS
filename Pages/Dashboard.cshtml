@page
@model TeknoSOS.WebApp.Pages.DashboardModel
@using Microsoft.AspNetCore.Identity
@inject UserManager<TeknoSOS.WebApp.Domain.Entities.ApplicationUser> UserManager
@{
    ViewData["Title"] = "Dashboard";
    var user = await UserManager.GetUserAsync(User);
    var firstName = user?.FirstName ?? User.Identity?.Name ?? "User";
}

<style>
    /* Dashboard Layout */
    .dashboard-wrapper {
        display: flex;
        min-height: calc(100vh - 70px);
    }
    
    /* Sidebar */
    .dashboard-sidebar {
        width: 260px;
        background: var(--ts-surface);
        border-right: 1px solid var(--ts-border);
        padding: 1.5rem 0;
        flex-shrink: 0;
        position: sticky;
        top: 70px;
        height: calc(100vh - 70px);
        overflow-y: auto;
    }
    
    .sidebar-brand {
        padding: 0 1.25rem 1.25rem;
        border-bottom: 1px solid var(--ts-border);
        margin-bottom: 1rem;
    }
    
    .sidebar-user {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    
    .sidebar-avatar {
        width: 42px;
        height: 42px;
        border-radius: var(--ts-radius);
        background: linear-gradient(135deg, var(--ts-primary), var(--ts-accent));
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 1rem;
    }
    
    .sidebar-user-info h6 {
        margin: 0;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--ts-text);
    }
    
    .sidebar-user-info span {
        font-size: 0.75rem;
        color: var(--ts-text-muted);
    }
    
    .sidebar-nav {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    
    .sidebar-section {
        padding: 0 1rem;
        margin-bottom: 0.5rem;
    }
    
    .sidebar-section-title {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--ts-text-muted);
        padding: 0.5rem 0.5rem 0.25rem;
    }
    
    .sidebar-link {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.65rem 0.75rem;
        border-radius: var(--ts-radius-sm);
        color: var(--ts-text-secondary);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        transition: all var(--ts-transition);
        margin-bottom: 0.15rem;
    }
    
    .sidebar-link:hover {
        background: var(--ts-primary-light);
        color: var(--ts-primary);
    }
    
    .sidebar-link.active {
        background: var(--ts-primary);
        color: white;
    }
    
    .sidebar-link i {
        font-size: 1.1rem;
        width: 20px;
        text-align: center;
    }
    
    .sidebar-link .badge {
        margin-left: auto;
        font-size: 0.65rem;
    }
    
    /* Main Content */
    .dashboard-main {
        flex: 1;
        padding: 1.5rem 2rem;
        background: var(--ts-bg);
        min-width: 0;
    }
    
    /* Header */
    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: 1rem;
    }
    
    .dashboard-header h1 {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--ts-text);
        margin: 0;
    }
    
    .dashboard-header p {
        font-size: 0.9rem;
        color: var(--ts-text-muted);
        margin: 0.25rem 0 0;
    }
    
    /* Stats Grid */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
        margin-bottom: 1.5rem;
    }
    
    .stat-card {
        background: var(--ts-surface);
        border: 1px solid var(--ts-border);
        border-radius: var(--ts-radius-lg);
        padding: 1.25rem;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        transition: all var(--ts-transition);
    }
    
    .stat-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--ts-shadow-md);
    }
    
    .stat-card.primary { border-left: 3px solid var(--ts-primary); }
    .stat-card.success { border-left: 3px solid var(--ts-success); }
    .stat-card.warning { border-left: 3px solid var(--ts-warning); }
    .stat-card.info { border-left: 3px solid var(--ts-info); }
    
    .stat-content h3 {
        font-size: 1.75rem;
        font-weight: 800;
        color: var(--ts-text);
        margin: 0 0 0.25rem;
        line-height: 1;
    }
    
    .stat-content p {
        font-size: 0.8rem;
        color: var(--ts-text-muted);
        margin: 0;
        text-transform: uppercase;
        font-weight: 600;
        letter-spacing: 0.03em;
    }
    
    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: var(--ts-radius);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }
    
    .stat-card.primary .stat-icon { background: var(--ts-primary-light); color: var(--ts-primary); }
    .stat-card.success .stat-icon { background: var(--ts-success-light); color: var(--ts-success); }
    .stat-card.warning .stat-icon { background: var(--ts-warning-light); color: var(--ts-warning); }
    .stat-card.info .stat-icon { background: var(--ts-info-light); color: var(--ts-info); }
    
    /* Content Grid */
    .content-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 1.5rem;
    }
    
    /* Cards */
    .dashboard-card {
        background: var(--ts-surface);
        border: 1px solid var(--ts-border);
        border-radius: var(--ts-radius-lg);
        overflow: hidden;
    }
    
    .dashboard-card-header {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--ts-border);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .dashboard-card-header h2 {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--ts-text);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .dashboard-card-header h2 i {
        color: var(--ts-primary);
    }
    
    .dashboard-card-body {
        padding: 1.25rem;
    }
    
    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 2.5rem 1rem;
    }
    
    .empty-state-icon {
        width: 64px;
        height: 64px;
        border-radius: var(--ts-radius-lg);
        background: var(--ts-bg-secondary);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        font-size: 1.75rem;
        color: var(--ts-text-muted);
    }
    
    .empty-state h3 {
        font-size: 1rem;
        font-weight: 600;
        color: var(--ts-text);
        margin: 0 0 0.5rem;
    }
    
    .empty-state p {
        font-size: 0.875rem;
        color: var(--ts-text-muted);
        margin: 0 0 1.25rem;
        max-width: 280px;
        margin-left: auto;
        margin-right: auto;
    }
    
    /* Quick Action Cards */
    .quick-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
    }
    
    .quick-action {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem;
        background: var(--ts-bg-secondary);
        border-radius: var(--ts-radius);
        text-decoration: none;
        transition: all var(--ts-transition);
    }
    
    .quick-action:hover {
        background: var(--ts-primary-light);
        transform: translateY(-1px);
    }
    
    .quick-action-icon {
        width: 40px;
        height: 40px;
        border-radius: var(--ts-radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }
    
    .quick-action:nth-child(1) .quick-action-icon { background: var(--ts-primary-light); color: var(--ts-primary); }
    .quick-action:nth-child(2) .quick-action-icon { background: var(--ts-success-light); color: var(--ts-success); }
    .quick-action:nth-child(3) .quick-action-icon { background: var(--ts-info-light); color: var(--ts-info); }
    .quick-action:nth-child(4) .quick-action-icon { background: var(--ts-accent-light); color: var(--ts-accent); }
    
    .quick-action-text h4 {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--ts-text);
        margin: 0;
    }
    
    .quick-action-text span {
        font-size: 0.75rem;
        color: var(--ts-text-muted);
    }
    
    /* Responsive */
    @@media (max-width: 1199.98px) {
        .stats-grid { grid-template-columns: repeat(2, 1fr); }
        .content-grid { grid-template-columns: 1fr; }
    }
    
    @@media (max-width: 991.98px) {
        .dashboard-sidebar {
            display: none;
        }
        
        .dashboard-main {
            padding: 1rem;
        }
    }
    
    @@media (max-width: 767.98px) {
        .stats-grid { grid-template-columns: 1fr; }
        .quick-actions { grid-template-columns: 1fr; }
        
        .dashboard-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }
    
    /* Mobile Bottom Nav */
    .mobile-nav {
        display: none;
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: var(--ts-surface);
        border-top: 1px solid var(--ts-border);
        padding: 0.5rem;
        z-index: 100;
    }
    
    .mobile-nav-list {
        display: flex;
        justify-content: space-around;
        list-style: none;
        margin: 0;
        padding: 0;
    }
    
    .mobile-nav-link {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.25rem;
        padding: 0.5rem 1rem;
        color: var(--ts-text-muted);
        text-decoration: none;
        font-size: 0.7rem;
        font-weight: 500;
        border-radius: var(--ts-radius-sm);
        transition: all var(--ts-transition);
    }
    
    .mobile-nav-link i { font-size: 1.25rem; }
    
    .mobile-nav-link.active,
    .mobile-nav-link:hover {
        color: var(--ts-primary);
        background: var(--ts-primary-light);
    }
    
    @@media (max-width: 767.98px) {
        .mobile-nav { display: block; }
        .dashboard-main { padding-bottom: 80px; }
    }
</style>

<div class="dashboard-wrapper">
    <!-- Sidebar -->
    <aside class="dashboard-sidebar">
        <div class="sidebar-brand">
            <div class="sidebar-user">
                <div class="sidebar-avatar">
                    @firstName[0]
                </div>
                <div class="sidebar-user-info">
                    <h6>@firstName</h6>
                    <span>@(user?.Email ?? "")</span>
                </div>
            </div>
        </div>
        
        <div class="sidebar-section">
            <div class="sidebar-section-title">Menu</div>
            <nav>
                <ul class="sidebar-nav">
                    <li>
                        <a href="/Dashboard" class="sidebar-link active">
                            <i class="bi bi-grid-1x2"></i>
                            Overview
                        </a>
                    </li>
                    <li>
                        <a href="/DefectList" class="sidebar-link">
                            <i class="bi bi-file-earmark-text"></i>
                            My Requests
                        </a>
                    </li>
                    <li>
                        <a href="/Chat" class="sidebar-link">
                            <i class="bi bi-chat-dots"></i>
                            Messages
                            <span class="badge bg-danger">0</span>
                        </a>
                    </li>
                    <li>
                        <a href="/ReportDefect" class="sidebar-link">
                            <i class="bi bi-plus-circle"></i>
                            New Request
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
        
        <div class="sidebar-section">
            <div class="sidebar-section-title">Account</div>
            <nav>
                <ul class="sidebar-nav">
                    <li>
                        <a href="/Account/Profile" class="sidebar-link">
                            <i class="bi bi-person"></i>
                            Profile
                        </a>
                    </li>
                    @if (user?.Role == TeknoSOS.WebApp.Domain.Enums.UserRole.Professional)
                    {
                        <li>
                            <a href="/Account/Certificates" class="sidebar-link">
                                <i class="bi bi-award"></i>
                                Certifikatat & Foto
                            </a>
                        </li>
                    }
                    <li>
                        <a href="/Identity/Account/Manage" class="sidebar-link">
                            <i class="bi bi-gear"></i>
                            Settings
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    </aside>
    
    <!-- Main Content -->
    <main class="dashboard-main">
        <div class="dashboard-header">
            <div>
                <h1>Mirë se erdhe, @firstName!</h1>
                <p>Ja një përmbledhje e aktivitetit tënd</p>
                <div class="mt-3 mb-2 p-3 bg-light rounded border">
                    <div><b>Emër:</b> @user?.FirstName</div>
                    <div><b>Mbiemër:</b> @user?.LastName</div>
                    <div><b>Username:</b> @(user?.DisplayUsername ?? user?.UserName)</div>
                    <div><b>Email:</b> @user?.Email</div>
                    <div><b>Data regjistrimit:</b> @user?.RegistrationDate.ToString("dd.MM.yyyy")</div>
                    @if (user?.Role == TeknoSOS.WebApp.Domain.Enums.UserRole.Professional)
                    {
                        <div class="mt-2 p-3 rounded border @(Model.IsSubscriptionExpired ? "bg-danger-subtle border-danger" : Model.IsSubscriptionExpiringSoon ? "bg-warning-subtle border-warning" : "bg-success-subtle border-success")">
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                                <div>
                                    <div class="fw-bold">Abonimi i teknikutit</div>
                                    @if (Model.IsSubscriptionExpired)
                                    {
                                        <div class="text-danger fw-semibold">Abonimi ka skaduar.</div>
                                    }
                                    else if (Model.IsSubscriptionExpiringSoon)
                                    {
                                        <div class="text-warning-emphasis fw-semibold">Abonimi po skadon së shpejti.</div>
                                    }
                                    else
                                    {
                                        <div class="text-success-emphasis fw-semibold">Abonimi aktiv.</div>
                                    }
                                </div>
                                <div class="text-end">
                                    <div class="display-6 fw-bold mb-0 @(Model.IsSubscriptionExpired ? "text-danger" : Model.IsSubscriptionExpiringSoon ? "text-warning" : "text-success")">@Model.DaysLeft</div>
                                    <small class="text-muted">ditë të mbetura</small>
                                </div>
                            </div>
                            @if (Model.IsSubscriptionExpired || Model.IsSubscriptionExpiringSoon)
                            {
                                <a href="/Account/SubscriptionRenewal" class="btn btn-sm btn-dark mt-2">
                                    <i class="bi bi-credit-card me-1"></i> Rinovo abonimin
                                </a>
                            }
                        </div>
                    }
                    <div><b>Punë të kryera (lifetime):</b> @Model.LifetimeJobsCompleted</div>
                    <div><b>Review të dhëna:</b> @Model.ReviewsGivenCount</div>
                    <div><b>Review të marra:</b> @Model.ReviewsReceivedCount</div>
                    <div><b>Review mesatare:</b> @Model.AverageRating.ToString("0.0") (@Model.ReviewsReceivedCount review)</div>
                </div>
                <form method="post" enctype="multipart/form-data" asp-page-handler="UploadDocument">
                    <div class="mb-2">
                        <label for="docUpload" class="form-label">Ngarko dokument</label>
                        <input type="file" name="Document" id="docUpload" class="form-control" />
                    </div>
                    <button type="submit" class="btn btn-warning">Ngarko (do konfirmohet nga admin)</button>
                </form>
                <div class="mt-2 text-muted small">Dokumentet e ngarkuara nuk shfaqen pa konfirmim nga admin.</div>
            </div>
            <a href="/ReportDefect" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i>
                Kërkesë e re
            </a>
        </div>
        
        <!-- Stats -->
        <div class="stats-grid">
            <div class="stat-card primary">
                <div class="stat-content">
                    <h3>@Model.TotalReports</h3>
                    <p>Kërkesat totale</p>
                </div>
                <div class="stat-icon">
                    <i class="bi bi-file-earmark-text"></i>
                </div>
            </div>
            
            <div class="stat-card success">
                <div class="stat-content">
                    <h3>@Model.ResolvedReports</h3>
                    <p>Të përfunduara</p>
                </div>
                <div class="stat-icon">
                    <i class="bi bi-check-circle"></i>
                </div>
            </div>
            
            <div class="stat-card warning">
                <div class="stat-content">
                    <h3>@Model.InProgressReports</h3>
                    <p>Në progres</p>
                </div>
                <div class="stat-icon">
                    <i class="bi bi-hourglass-split"></i>
                </div>
            </div>
            
            <div class="stat-card info">
                <div class="stat-content">
                    <h3>@Model.TotalMessages</h3>
                    <p>Mesazhe</p>
                </div>
                <div class="stat-icon">
                    <i class="bi bi-chat-dots"></i>
                </div>
            </div>
        </div>
        
        <!-- Content Grid -->
        <div class="content-grid">
            <!-- Recent Activity -->
            <div class="dashboard-card">
                <div class="dashboard-card-header">
                    <h2><i class="bi bi-clock-history"></i> Aktiviteti i fundit</h2>
                    <a href="/DefectList" class="btn btn-sm btn-ghost">Shiko të gjitha</a>
                </div>
                <div class="dashboard-card-body">
                    <div class="empty-state">
                        <div class="empty-state-icon">
                            <i class="bi bi-inbox"></i>
                        </div>
                        <h3>Asnjë aktivitet ende</h3>
                        <p>Krijo kërkesën tënde të parë për të filluar të përdorësh TeknoSOS</p>
                        <a href="/ReportDefect" class="btn btn-primary btn-sm">
                            <i class="bi bi-plus-lg me-1"></i>
                            Krijo kërkesë
                        </a>
                    </div>
                </div>
            </div>
            
            <!-- Profili & Statusi -->
            <div class="dashboard-card">
                <div class="dashboard-card-header">
                    <h2><i class="bi bi-person-badge"></i> Profili & Statusi</h2>
                    <a href="/Account/Profile" class="btn btn-sm btn-ghost">Modifiko Profilin</a>
                </div>
                <div class="dashboard-card-body">
                    <div class="mb-2">
                        <b>Statusi i profilit:</b>
                        @if (user?.IsProfileVerified == true)
                        {
                            <span class="badge bg-success"><i class="bi bi-check-circle"></i> I verifikuar</span>
                        }
                        else if (user?.IsInTrialPeriod == true)
                        {
                            <span class="badge bg-info text-dark"><i class="bi bi-hourglass-split"></i> Në provë</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark"><i class="bi bi-clock"></i> Në pritje verifikimi</span>
                        }
                    </div>
                    <div class="mb-2">
                        <b>Statusi i punës:</b>
                        @if (user?.Role == TeknoSOS.WebApp.Domain.Enums.UserRole.Professional)
                        {
                            <form method="post" asp-page-handler="ChangeStatus" class="d-inline">
                                <select name="workStatus" class="form-select form-select-sm d-inline w-auto" onchange="this.form.submit()">
                                    <option value="available" selected="@(user?.IsAvailableForWork == true ? "selected" : null)">I disponueshëm</option>
                                    <option value="unavailable" selected="@(user?.IsAvailableForWork == false ? "selected" : null)">Jo i disponueshëm</option>
                                </select>
                            </form>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Klient</span>
                        }
                    </div>
                    <div class="mb-2">
                        <b>Certifikatat:</b>
                        @if (user?.Certificates != null && user.Certificates.Count > 0)
                        {
                            <span class="badge bg-primary"><i class="bi bi-award"></i> @user.Certificates.Count të ngarkuara</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Asnjë certifikatë</span>
                        }
                        <a href="/Account/Certificates" class="btn btn-link btn-sm ms-2">Menaxho certifikatat</a>
                    </div>
                    @if (!string.IsNullOrEmpty(user?.Bio))
                    {
                        <div class="mb-2">
                            <b>Rreth meje:</b>
                            <div class="border rounded p-2 bg-light small">@user.Bio</div>
                        </div>
                    }
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="dashboard-card">
                <div class="dashboard-card-header">
                    <h2><i class="bi bi-lightning-charge"></i> Veprime të shpejta</h2>
                </div>
                <div class="dashboard-card-body">
                    <div class="quick-actions">
                        <a href="/ReportDefect" class="quick-action">
                            <div class="quick-action-icon">
                                <i class="bi bi-plus-lg"></i>
                            </div>
                            <div class="quick-action-text">
                                <h4>Kërkesë e re</h4>
                                <span>Raporto një problem</span>
                            </div>
                        </a>
                        
                        <a href="/DefectList" class="quick-action">
                            <div class="quick-action-icon">
                                <i class="bi bi-list-check"></i>
                            </div>
                            <div class="quick-action-text">
                                <h4>Kërkesat e mia</h4>
                                <span>Shiko historikun</span>
                            </div>
                        </a>
                        
                        <a href="/Chat" class="quick-action">
                            <div class="quick-action-icon">
                                <i class="bi bi-chat-dots"></i>
                            </div>
                            <div class="quick-action-text">
                                <h4>Mesazhe</h4>
                                <span>Komuniko me teknikanë</span>
                            </div>
                        </a>
                        
                        <a href="/Account/Profile" class="quick-action">
                            <div class="quick-action-icon">
                                <i class="bi bi-person"></i>
                            </div>
                            <div class="quick-action-text">
                                <h4>Profili</h4>
                                <span>Ndrysho të dhënat</span>
                            </div>
                        </a>

                        @if (user?.Role == TeknoSOS.WebApp.Domain.Enums.UserRole.Professional)
                        {
                            <a href="/Account/SubscriptionRenewal" class="quick-action">
                                <div class="quick-action-icon">
                                    <i class="bi bi-credit-card-2-front"></i>
                                </div>
                                <div class="quick-action-text">
                                    <h4>Abonimi</h4>
                                    <span>Rinovo ose menaxho pagesën</span>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<!-- Mobile Bottom Navigation -->
