@page
@model TeknoSOS.WebApp.Pages.Admin.BacklinksModel
@{
    ViewData["Title"] = "Backlinks Generator";
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
}

<h2 class="fw-bold mb-4"><i class="bi bi-link-45deg text-primary"></i> Backlinks Generator</h2>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white">
        <h5 class="mb-0"><i class="bi bi-graph-up-arrow text-success"></i> Gjenero Backlink për Trafik</h5>
    </div>
    <div class="card-body">
        <form method="post">
            <div class="mb-3">
                <label class="form-label fw-semibold">URL e Faqes</label>
                <input name="TargetUrl" class="form-control" placeholder="https://shembull.com/artikull" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Titulli i Linkut</label>
                <input name="LinkTitle" class="form-control" placeholder="Titulli i artikullit ose faqes" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Anchor Text</label>
                <input name="AnchorText" class="form-control" placeholder="Teksti i klikueshëm (anchor)" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Rel Attribute</label>
                <select name="RelAttribute" class="form-select">
                    <option value="nofollow">nofollow</option>
                    <option value="dofollow">dofollow</option>
                    <option value="sponsored">sponsored</option>
                    <option value="ugc">ugc</option>
                </select>
            </div>
            <button class="btn btn-primary"><i class="bi bi-link-45deg"></i> Gjenero Backlink</button>
        </form>
        @if (Model.GeneratedBacklink != null)
        {
            <div class="alert alert-success mt-4">
                <label class="fw-semibold">Backlink i Gjeneruar:</label>
                <pre class="bg-light p-2 border rounded">@Model.GeneratedBacklink</pre>
            </div>
        }
    </div>
</div>
