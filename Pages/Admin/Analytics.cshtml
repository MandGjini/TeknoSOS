@page
@model TeknoSOS.WebApp.Pages.Admin.AnalyticsModel
@{
    ViewData["Title"] = "Analitika e Platformës";
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <h2 class="fw-bold mb-4"><i class="bi bi-bar-chart-line text-primary"></i> Analitika e Platformës</h2>
    <div class="row g-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Vizitorë Unikë</h5>
                    <h2 class="fw-bold text-primary">@Model.UniqueVisitors</h2>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Regjistrime të Reja</h5>
                    <h2 class="fw-bold text-success">@Model.NewRegistrations</h2>
                </div>
            </div>
        </div>
    </div>
    <div class="row mt-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Google Analytics</h5>
                    <iframe src="https://analytics.google.com/analytics/web/" width="100%" height="400" frameborder="0"></iframe>
                </div>
            </div>
        </div>
    </div>
</div>
