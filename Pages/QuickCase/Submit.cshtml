@page
@model TeknoSOS.WebApp.Pages.QuickCase.SubmitModel

<h2>Shto një rast të shpejtë</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<form method="post">
    <div class="mb-3">
        <label class="form-label">Emri (opsional)</label>
        <input asp-for="Input.Name" class="form-control" />
        <span asp-validation-for="Input.Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Email (opsional)</label>
        <input asp-for="Input.Email" class="form-control" />
        <span asp-validation-for="Input.Email" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Telefoni (opsional)</label>
        <input asp-for="Input.Phone" class="form-control" />
        <span asp-validation-for="Input.Phone" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Titulli</label>
        <input asp-for="Input.Title" class="form-control" />
        <span asp-validation-for="Input.Title" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Përshkrimi</label>
        <textarea asp-for="Input.Description" class="form-control" rows="6"></textarea>
        <span asp-validation-for="Input.Description" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Dërgo rastin</button>
</form>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}
